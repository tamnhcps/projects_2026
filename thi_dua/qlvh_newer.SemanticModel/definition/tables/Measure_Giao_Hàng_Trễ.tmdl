	measure '% Trễ hạn_DH (Giao thông thường)' =
			
			CALCULATE(
			    [% Trễ hạn_DH],
			    FILTER(
			        'F_Logistics 2',
			        'F_Logistics 2'[loại giao hàng] = "Giao thông thường"
			    )
			)
		displayFolder: Giao hàng combined\Phân loại trễ hạn
		lineageTag: ff081178-3737-4cab-9d06-323c381dd5c7

		changedProperty = DisplayFolder

		changedProperty = Name

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure '% Trễ DH_2h' =
			
			VAR actual = [% Trễ hạn_DH (Giao 2 giờ)]
			VAR target = 0.15
			VAR score =
			    DIVIDE(target - actual, target)
			RETURN
			IF(
			    ISBLANK(actual),
			    BLANK(),           -- không có data → không tính
			    MAX(
			        -1.2,
			        MIN(
			            1.2,
			            ROUND(score, 4)
			        )
			    )
			)
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Giao hàng combined\Phân loại trễ hạn
		lineageTag: 03a69173-31de-48e0-aaf3-3653d2bc9dda

		changedProperty = DisplayFolder

		changedProperty = Name

		changedProperty = FormatString

	measure '% Trễ DH_TT' =
			
			VAR actual = [% Trễ hạn_DH (Giao thông thường)]
			VAR target_default = 0.15
			VAR target_zone3   = 0.2
			VAR zone = SELECTEDVALUE('adhoc_shop_zone_mappings'[zone])
			
			VAR target =
			    IF(
			        zone = "Zone 3",
			        target_zone3,
			        target_default
			    )
			
			VAR score =
			    DIVIDE(target - actual, target)
			
			RETURN
			IF(
			    ISBLANK(actual),
			    BLANK(),
			    MAX(
			        -1.2,
			        MIN(
			            1.2,
			            ROUND(score, 4)
			        )
			    )
			)
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Giao hàng combined\Phân loại trễ hạn
		lineageTag: 4e98b42b-d6f2-4a91-b424-5ebbebcf052c

		changedProperty = DisplayFolder

		changedProperty = Name

		changedProperty = FormatString

