	/// *Không bao gồm phiếu có tổng thời gian giao hàng vượt quá 1 tuần
	measure 'TG xử lý SP ra RT' = EXTERNALMEASURE("TG xử lý SP ra RT", DOUBLE, "DirectQuery to AS - LOG_Logistics tổng quan")
		displayFolder: Giao hàng combined\Thời gian giao hàng
		lineageTag: e395c120-ac74-4666-967a-48061ac8b705
		sourceLineageTag: df3b6cef-d7f2-49f8-a4f5-b3a808d5ca95
