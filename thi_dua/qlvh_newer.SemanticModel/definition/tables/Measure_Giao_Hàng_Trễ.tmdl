	/// (Ngày lập phiếu SP   - Ngày đơn hàng) ) trung bình (DVT: giờ)
	/// *Không bao gồm phiếu có tổng thời gian giao hàng vượt quá 1 tuần
	measure 'TG xử lý DH ra SP' = EXTERNALMEASURE("TG xử lý DH ra SP", DOUBLE, "DirectQuery to AS - LOG_Logistics tổng quan")
		formatString: #,0.00
