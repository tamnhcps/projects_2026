	column Is_C-Brand =
			
			IF (
			   'D_Sản phẩm'[Nhóm hàng] = "REALME CTM"
			   ||'D_Sản phẩm'[Nhóm hàng] =  "OPPO CTM"
			        ||'D_Sản phẩm'[Nhóm hàng] = "VIVO CTM"
			        ||'D_Sản phẩm'[Nhóm hàng] = "NUBIA CTM"
			        ||'D_Sản phẩm'[Nhóm hàng] = "TCL MỚI"
			        ||'D_Sản phẩm'[Nhóm hàng] = "ONEPLUS CTM"
			        ||'D_Sản phẩm'[Nhóm hàng] = "BENCO CTM",
			    1,
			    BLANK ()
			)
		formatString: 0
		lineageTag: a5c3e64a-0d7f-4ad6-ab07-dbfba8427285
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column ten_hang_cha
		dataType: string
		lineageTag: 6236cd8c-f991-4e0f-b19d-004c886d1e5c
