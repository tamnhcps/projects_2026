	column Ngày_IsActive =
			
			VAR mindate =
			    MIN ( 'Kết quả đánh giá Shop'[Tháng] )
			VAR maxdate =
			    // MAX ( 'FACT_Sale_Doanh số bán'[Date] )
			    MAX(CurrentDate[Date])-1
			RETURN
			    IF (
			        'DIM_Danh mục_Ngày'[Date] >= mindate
			            && 'DIM_Danh mục_Ngày'[Date] <= maxdate,
			        1,
			        BLANK ()
			    )
		formatString: 0
		lineageTag: 1422f9ad-372e-4a0f-b10e-e3ad353edcf1
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column 'Giai đoạn' =
			
			VAR nam_max =
			    CALCULATE (
			        MAX ( 'DIM_Danh mục_Ngày'[Năm] ),
			        FILTER (
			            'DIM_Danh mục_Ngày',
			            'DIM_Danh mục_Ngày'[Tháng_IsActive] = 1
			        )
			    )
			VAR thang_max =
			    CALCULATE (
			        MAX ( 'DIM_Danh mục_Ngày'[Tháng] ),
			        FILTER (
			            'DIM_Danh mục_Ngày',
			            'DIM_Danh mục_Ngày'[Tháng_IsActive] = 1
			                && 'DIM_Danh mục_Ngày'[Năm] = nam_max
			        )
			    )
			VAR thang_group =
			    SWITCH (
			        TRUE (),
			        'DIM_Danh mục_Ngày'[Tháng] < thang_max,
			            "01 - "
			                & FORMAT (
			                    thang_max - 1,
			                    "0#"
			                ) & "/"
			                & FORMAT (
			                    nam_max,
			                    "#"
			                ),
			        'DIM_Danh mục_Ngày'[Tháng] = thang_max, "Tháng hiện tại",
			        FORMAT (
			            thang_max + 1,
			            "0#"
			        ) & " - 12/"
			            & FORMAT (
			                nam_max,
			                "#"
			            )
			    )
			RETURN
			    SWITCH (
			        TRUE (),
			        'DIM_Danh mục_Ngày'[Năm] = nam_max , thang_group,
			        FORMAT (
			            'DIM_Danh mục_Ngày'[Năm],
			            "#"
			        )
			    )
		lineageTag: 74c083d4-1f9b-485e-9cbe-fd868a2b5822
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column Tháng_IsActive =
			
			var monthx = calculate(sum('DIM_Danh mục_Ngày'[Ngày_IsActive]),filter('DIM_Danh mục_Ngày','DIM_Danh mục_Ngày'[Năm/Tháng] = earlier('DIM_Danh mục_Ngày'[Năm/Tháng])))
			return if(monthx > 0,1,BLANK())
		formatString: 0
		lineageTag: 3d8e08af-2019-4da6-a081-d362f4799c15
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column Ngày_ActiveLog =
			
			VAR mindate =
			    MIN ( 'Kết quả đánh giá Shop'[Tháng] )
			VAR maxdate =
			    MAX ( 'FACT_Sale_Doanh số bán'[Date] )
			RETURN
			    IF (
			        'DIM_Danh mục_Ngày'[Date] >= DATE(YEAR(mindate), MONTH(mindate), 1)
			            && 'DIM_Danh mục_Ngày'[Date] <= maxdate,
			        1,
			        BLANK ()
			    )
		formatString: 0
		lineageTag: 837684c1-b030-4311-a784-d8ba69cce507
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column Ngày_curr =
			
			VAR _date =
			    MAX(CurrentDate[Date])
			RETURN
			    IF (
			        'DIM_Danh mục_Ngày'[Date] = _date,
			        1,
			        BLANK ()
			    )
		formatString: 0
		lineageTag: b5e919b9-c28e-4ed4-866e-f06fd1384530
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

