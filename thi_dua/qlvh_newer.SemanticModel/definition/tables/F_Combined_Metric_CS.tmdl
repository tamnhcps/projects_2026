	partition F_Combined_Metric_CS = m
		mode: import
		queryGroup: NLVH
		source =
				let
				    Source = Value.NativeQuery(GoogleBigQuery.Database([BillingProject="cellphones-data-platform"]){[Name="cellphones-data-platform"]}[Data], "---""dataset_id=6e97d189-0524-457d-bd6e-30d5e5ad63ad""#(lf)#(lf)select#(lf)  mien,#(lf)  am,#(lf)  bo_phan,#(lf)  date(date) date,#(lf)  -- tổng hợp số lượng#(lf)  sum(Target_daily) target_daily_khtn,#(lf)  sum(transaction_by_phone) as transaction_by_phone,#(lf)  sum(total_opportunities) as total_opportunities,#(lf)  sum(khtn_customer) as khtn_customer,#(lf)  sum(caring_isoverdue) as caring_isoverdue,#(lf)#(lf)  sum(luot_tai_app) as luot_tai_app,#(lf)  sum(chua_co_app) as chua_co_app,#(lf)#(lf)  sum(slg_onl) as slg_onl,#(lf)  sum(slg_dh_onl) as slg_dh_onl,#(lf)  sum(slg_sp_onl) as slg_sp_onl,#(lf)#(lf)  -- trung bình SLA (chuyển về giây trước khi tính)#(lf)  FORMAT(#(lf)      ""%02d:%02d:%02d"",#(lf)      CAST(AVG(total_seconds) / 3600 AS INT64),                         -- hours#(lf)      CAST(MOD(CAST(AVG(total_seconds) AS INT64), 3600) / 60 AS INT64), -- minutes#(lf)      CAST(MOD(CAST(AVG(total_seconds) AS INT64), 60) AS INT64)         -- seconds#(lf)    ) AS avg_sla_hhmmss,#(lf)#(lf)  sum(so_luong_phieu_co_tu_van) as so_luong_phieu_co_tu_van,#(lf)  sum(so_luong_phieu_khong_tu_van) as so_luong_phieu_khong_tu_van,#(lf)  sum(so_luong_phieu_tu_van) as so_luong_phieu_tu_van#(lf)from cellphones-data-platform.cps_sales_datamart.combined_evaluation_metric_cs_by_shop#(lf)group by date(date), mien,am, bo_phan", null, [EnableFolding=true])
				in
				    Source

