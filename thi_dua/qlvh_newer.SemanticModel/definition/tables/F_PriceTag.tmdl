	partition F_PriceTag = m
		mode: import
		queryGroup: NLVH
		source =
				let
				    Source = Value.NativeQuery(GoogleBigQuery.Database([BillingProject="cellphones-data-platform"]){[Name="cellphones-data-platform"]}[Data], "-- dataset_id=6e97d189-0524-457d-bd6e-30d5e5ad63ad#(lf)#(lf)WITH cte AS (#(lf)  SELECT *#(lf)  FROM `cellphones-data-platform.cps_postgre_data_report_dwh.product_price_tags_log_hcm_hn`#(lf)),#(lf)#(lf)cte_raw AS (#(lf)  SELECT #(lf)    x.productcode,#(lf)    x.elton_process_date AS date,#(lf)    y.name AS branchname#(lf)  FROM cte x#(lf)  LEFT JOIN `cellphones-data-platform.cps_cdc_sep_hcm_dbo.ERP_SubBranch` y#(lf)    ON x.branchid = y.id#(lf)  WHERE elton_process_date >= DATE('2025-09-01')#(lf)),#(lf)#(lf)san_pham AS (#(lf)  SELECT#(lf)    ma_hang,#(lf)    COALESCE(web_parent_product_name, ten_hang) AS ten_hang_cha#(lf)  FROM `cellphones-data-platform.cps_DA_General_Transform.dim_product`#(lf))#(lf)#(lf)SELECT #(lf)  cte_raw.date,#(lf)  cte_raw.branchname,#(lf)  COUNT(DISTINCT san_pham.ten_hang_cha) AS Count_MaChaWeb#(lf)FROM cte_raw#(lf)JOIN san_pham #(lf)  ON cte_raw.productcode = san_pham.ma_hang#(lf)GROUP BY #(lf)  cte_raw.date,#(lf)  cte_raw.branchname#(lf)ORDER BY #(lf)  cte_raw.date,#(lf)  cte_raw.branchname", null, [EnableFolding=true])
				in
				    Source

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

