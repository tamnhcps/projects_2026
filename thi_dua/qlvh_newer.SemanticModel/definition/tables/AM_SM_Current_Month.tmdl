	column MNV_SM =
			
			var sm =
			CALCULATE(VALUES('FACT_Đánh giá SM'[Ma_TenSM]), FILTER('FACT_Đánh giá SM', 'FACT_Đánh giá SM'[SHOP] = EARLIER(AM_SM_Current_Month[SHOP]) && 'FACT_Đánh giá SM'[StartDate] = EARLIER(AM_SM_Current_Month[StartDate]) && 'FACT_Đánh giá SM'[SM/SUP] = EARLIER(AM_SM_Current_Month[SM/SUP])))
			return IF(ISBLANK(sm), AM_SM_Current_Month[SM/SUP], sm)
