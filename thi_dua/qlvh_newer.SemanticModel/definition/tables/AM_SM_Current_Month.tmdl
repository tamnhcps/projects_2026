	column AM = CALCULATE(VALUES('DIM_Danh mục_Shop_AM'[AM]), FILTER('DIM_Danh mục_Shop_AM', 'DIM_Danh mục_Shop_AM'[SHOP] = EARLIER(AM_SM_Current_Month[SHOP]) && 'DIM_Danh mục_Shop_AM'[StartDate] = EARLIER(AM_SM_Current_Month[StartDate])))
