	column Custom
		dataType: string
		lineageTag: aa1dfe86-4943-4f3e-b94b-e1c1b8f36549
		summarizeBy: none
		sourceColumn: Custom

		annotation SummarizationSetBy = Automatic

	column Ma_Kho = ```
			
			VAR _OneRow =
			    TOPN(
			        1,
			        FILTER(
			            'DIM_Phân quyền vận hành',
			            'DIM_Phân quyền vận hành'[Cửa hàng] = 'DIM_Danh mục_Phòng ban'[Cửa hàng]
			                && NOT CONTAINSSTRING( 'DIM_Phân quyền vận hành'[Mã kho], "KM" )
			        ),
			        'DIM_Phân quyền vận hành'[Mã kho]
			    )
			RETURN
			MAXX(_OneRow, 'DIM_Phân quyền vận hành'[Mã kho])
			
			```
		lineageTag: 4758b7ab-f250-41ac-a9ee-c213405a2f96
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column OP =
			
			VAR Mien =
			    LOOKUPVALUE(
			        'DIM_Danh mục_Kho'[Miền],
			        'DIM_Danh mục_Kho'[Mã kho], 'DIM_Danh mục_Phòng ban'[Ma_Kho]
			    )
			RETURN
			    LOOKUPVALUE( 'DIM_Phân quyền vận hành_Vùng'[Tên],'DIM_Phân quyền vận hành_Vùng'[Miền],Mien)
		lineageTag: 440a1e0b-b2a6-48c4-a28a-4348c4979a73
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column Leader = LOOKUPVALUE('DIM_Phân quyền user'[Leader],'DIM_Phân quyền user'[Tên],'DIM_Danh mục_Phòng ban'[Cửa hàng],BLANK())
		lineageTag: c95f96f9-64af-4193-9b9b-0a366e7930c7
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

