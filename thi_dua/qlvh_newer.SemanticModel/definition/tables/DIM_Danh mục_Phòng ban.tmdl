	column 'Key City' =
			SWITCH(
				TRUE,
				ISBLANK('DIM_Danh mục_Phòng ban'[Province]),
				"(Blank)",
				'DIM_Danh mục_Phòng ban'[Province] IN {"Hà Nội",
					"Hồ Chí Minh"},
				"Key City",
				'DIM_Danh mục_Phòng ban'[Province] IN {"An Giang",
					"Bà Rịa - Vũng Tàu",
