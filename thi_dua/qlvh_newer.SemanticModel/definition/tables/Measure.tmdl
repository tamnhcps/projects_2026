	measure 'Đánh giá Quý_SM' =
			
			VAR _score = AVERAGE('Kết quả đánh giá Shop'[Kds/Score])
			VAR _diem = AVERAGE('Kết quả đánh giá Shop'[Tổng chỉ tiêu đạt])
			RETURN
			SWITCH(
			    TRUE(),
			    _score >= 1 && _diem >= 9, "Xuất sắc tuyệt đối",
			    _score >= 0.8 && _diem >= 7, "Tốt",
			    _score >= 0.7 && _diem >= 5, "Khá",
			    _score >= 0.5 && _diem >= 3, "Kém",
			    _score < 0.5 && _diem < 3, "Cảnh cáo",
			    "Cảnh cáo"
			)
		displayFolder: 3. Đánh giá SM
		lineageTag: fbd2ecba-2373-4cc2-bdb4-04813870eed0

