	measure 'Số cửa hàng đánh giá_SM' = ```
			
			var xstd = CALCULATE(COUNTROWS('Kết quả đánh giá Shop'), FILTER('DIM_Danh mục_Đánh giá', 'DIM_Danh mục_Đánh giá'[Đánh giá cuối cùng] = "Xuất sắc tuyệt đối"))
			var tot = CALCULATE(COUNTROWS('Kết quả đánh giá Shop'), FILTER('DIM_Danh mục_Đánh giá', 'DIM_Danh mục_Đánh giá'[Đánh giá cuối cùng] = "Tốt"))
			var kha = CALCULATE(COUNTROWS('Kết quả đánh giá Shop'), FILTER('DIM_Danh mục_Đánh giá', 'DIM_Danh mục_Đánh giá'[Đánh giá cuối cùng] = "Khá"))
			var kem = CALCULATE(COUNTROWS('Kết quả đánh giá Shop'), FILTER('DIM_Danh mục_Đánh giá', 'DIM_Danh mục_Đánh giá'[Đánh giá cuối cùng] = "Kém"))
			var canhcao = CALCULATE(COUNTROWS('Kết quả đánh giá Shop'), FILTER('DIM_Danh mục_Đánh giá', 'DIM_Danh mục_Đánh giá'[Đánh giá cuối cùng] = "Cảnh cáo"))
			return IF(xstd + tot + kha + kem + canhcao = 0, BLANK(),             
			            IF( xstd > 0, "Xuất sắc tuyệt đối " & xstd & " | ", BLANK() )
			            & IF( tot > 0, "Tốt " & tot & " | ", BLANK() )        
			            & IF( kha > 0, "Khá " & kha & " | ", BLANK() )
			            & IF( kem > 0, "Kém " & kem & " | ", BLANK() )
			            & IF( canhcao > 0, "Cảnh cáo " & canhcao, BLANK() ))
			```
		displayFolder: 3. Đánh giá SM
		lineageTag: 957c0d57-a17b-43ba-9058-aaeb2c78547c

