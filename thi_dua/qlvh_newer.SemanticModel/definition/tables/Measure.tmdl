	measure 'Nhân sự còn lại' = ```
			
			IF (
			    MAX ( 'DIM_Danh mục_Ngày'[Năm] ) >= 2022,
			        CALCULATE (
			            SUM ( 'F_Employee'[NhanSuConLai] ),
			            FILTER (
			                'F_Employee',
			                'F_Employee'[IsChinhThuc] = 0
			            ),
			            FILTER (
			                'DIM_Danh mục_Ngày',
			                'DIM_Danh mục_Ngày'[Năm/Tháng_Index] = MAX ( 'DIM_Danh mục_Ngày'[Năm/Tháng_Index] )
			            ),
