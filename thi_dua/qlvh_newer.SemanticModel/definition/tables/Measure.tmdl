		formatString: 0.00
		displayFolder: 1. Đánh giá Shop
		lineageTag: f6b19e01-8985-4b56-a06b-57863cb1d93c

	measure 'Đánh giá_Shop' =
			
			var zTotal = [Điểm quy đổi_Shop]
			var AM =
			SWITCH( true(),
			zTotal =  BLANK(), BLANK(),
			zTotal > 3.5, "Xuất sắc tuyệt đối",
			zTotal >= 2.5, "Tốt",
			zTotal >= 1.5, "Khá",
			zTotal < 1.5, "Kém",
			BLANK())
			var SM = CONCATENATEX( VALUES( 'FACT_Đánh giá Shop'[Đánh giá cuối cùng] ), 'FACT_Đánh giá Shop'[Đánh giá cuối cùng], ", " )
			return IF ( ISINSCOPE ( AM_SM_Current_Month[SM/SUP] ), SM, IF ( ISINSCOPE ( AM_SM_Current_Month[AM] ), AM, BLANK()))
		displayFolder: 1. Đánh giá Shop
		lineageTag: df80e941-6f42-48da-870e-e625d5eb2b03

