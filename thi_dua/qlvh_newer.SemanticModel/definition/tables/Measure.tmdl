			var kha = CALCULATE(DISTINCTCOUNT('FACT_Đánh giá AM'[Cửa hàng_NamThang]), FILTER('FACT_Đánh giá AM', 'FACT_Đánh giá AM'[Đánh giá cuối cùng] = "Khá"))
			var kem = CALCULATE(DISTINCTCOUNT('FACT_Đánh giá AM'[Cửa hàng_NamThang]), FILTER('FACT_Đánh giá AM', 'FACT_Đánh giá AM'[Đánh giá cuối cùng] = "Kém"))
			return IF(xstd + tot + kha + kem = 0, BLANK(),             
			            IF( xstd > 0, "Xuất sắc tuyệt đối " & xstd & " | ", BLANK() )
			            & IF( tot > 0, "Tốt " & tot & " | ", BLANK() )        
			            & IF( kha > 0, "Khá " & kha & " | ", BLANK() )
			            & IF( kem > 0, "Kém " & kem & " | ", BLANK() ))
			```
		displayFolder: 4. Đánh giá AM
