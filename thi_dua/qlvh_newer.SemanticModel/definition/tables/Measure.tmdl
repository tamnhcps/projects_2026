			var quy = SUMMARIZE(FILTER('FACT_Đánh giá SM', 'FACT_Đánh giá SM'[Quý] <> BLANK()), 'FACT_Đánh giá SM'[MNV],'FACT_Đánh giá SM'[Quý], "DanhGiaQ", [Đánh giá Quý_SM])
