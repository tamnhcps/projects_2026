	measure 'Số tháng đánh giá_AM' = ```
			
			var xstd = CALCULATE(DISTINCTCOUNT('FACT_Đánh giá AM'[Cửa hàng_NamThang]), FILTER('FACT_Đánh giá AM', 'FACT_Đánh giá AM'[Đánh giá cuối cùng] = "Xuất sắc tuyệt đối"))
