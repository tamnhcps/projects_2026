	measure 'Slg Android' = ```
			
			VAR Slg_nhom1 =
			    CALCULATE (
			        [Slg],
			        FILTER (
			            'DIM_Danh mục_Nhóm hàng',
			            'DIM_Danh mục_Nhóm hàng'[Nhóm] = "ANDROID"
			            && 'DIM_Danh mục_Nhóm hàng'[Thuộc tính]= "MỚI"
			            && 'DIM_Danh mục_Nhóm hàng'[Phân nhóm] = "NHÓM 1"
			            && 'DIM_Danh mục_Nhóm hàng'[Nhóm hàng] <> "NOKIA CTM"
			        ),      
			        FILTER (
			            'D_Sản phẩm',
			            'D_Sản phẩm'[Android_exp] = BLANK () 
			        )
			    )
			VAR Slg_nhom2 =
			    CALCULATE (
			        [Slg],
			        FILTER (
			            'DIM_Danh mục_Nhóm hàng',
			            'DIM_Danh mục_Nhóm hàng'[Nhóm] = "ANDROID"
			                && 'DIM_Danh mục_Nhóm hàng'[Thuộc tính]= "MỚI"
			                && 'DIM_Danh mục_Nhóm hàng'[Phân nhóm] = "NHÓM 2"
			        )
			    )
			VAR Slg_nhom3 =
			    CALCULATE (
			        [Slg],
			        FILTER (
			            'DIM_Danh mục_Nhóm hàng',
			            'DIM_Danh mục_Nhóm hàng'[Nhóm] = "ANDROID"
			            && 'DIM_Danh mục_Nhóm hàng'[Thuộc tính]= "MỚI"
			            && 'DIM_Danh mục_Nhóm hàng'[Phân nhóm] = "NHÓM 3"
			            && 'DIM_Danh mục_Nhóm hàng'[Nhóm hàng] <> "MASSTEL CTM"
			        ),      
			        FILTER (
			            'D_Sản phẩm',
			            'D_Sản phẩm'[Android_exp] = BLANK () 
			        )
			    )
			VAR Slg_android = Slg_nhom1 + Slg_nhom2 + Slg_nhom3
			RETURN
			    Slg_android
			```
		displayFolder: 2. Chỉ tiêu
		lineageTag: fcbe3c74-a8e0-4fc2-bee0-e8782997c588

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Kds =
			
			var dso = DIVIDE([Dso], [Target Dso])
			var bankem = DIVIDE([Dso Bán kèm], [Target Bán kèm])
			var pk1 = DIVIDE([Dso PK1], [Target PK1])
			var pk2 = DIVIDE([Dso PK2], [Target PK2])
			var android = DIVIDE([Slg Android], [Target Android])
			return dso * 0.4 + bankem * 0.2 + pk1 * 0.2 + pk2 * 0.1 + android * 0.1
		formatString: #,0.00%;-#,0.00%;#,0.00%
		displayFolder: 2. Chỉ tiêu
		lineageTag: e4363278-8a19-4fef-b936-3f076812b4d6

