	measure filter_show = ```
			
			--Thời gian
			// VAR zf_NamThang =
			//     OR(ISFILTERED( 'DIM_Danh mục_Ngày'[Date] ), ISFILTERED( 'DIM_Danh mục_Ngày'[Giai đoạn] ))
			// VAR zNamThang =
			//     "<a> <span style='color:#C6B497'> <b> Năm tháng: </b> </a>"
			//         // & CONCATENATEX( VALUES( Dim_Date[date] ), Dim_Date[date], ", " ) & "."
			//         & "Từ " & MIN('DIM_Danh mục_Ngày'[Date])
			//         & " đến " & MAX('DIM_Danh mục_Ngày'[Date]) & "."
			--Địa điểm
			VAR zf_Mien =
			    ISFILTERED( 'DIM_Danh mục_Miền'[Miền] )
			VAR zMien =
			    "<a> <span style='color:#C6B497'> <b> Miền: </b> </a>"
			        & CONCATENATEX( VALUES( 'DIM_Danh mục_Miền'[Miền] ), 'DIM_Danh mục_Miền'[Miền], ", " ) & "."
			
			VAR zf_TinhThanh =
			    ISFILTERED( 'DIM_Danh mục_Phòng ban'[Province] )
			VAR zTinhThanh =
			    "<a> <span style='color:#C6B497'> <b> Tỉnh thành: </b> </a>"
			        & CONCATENATEX( VALUES( 'DIM_Danh mục_Phòng ban'[Province] ), 'DIM_Danh mục_Phòng ban'[Province], ", " ) & "."
			
			VAR zf_TenShop =
			    ISFILTERED( 'DIM_Danh mục_Phòng ban'[Cửa hàng] )
			VAR zTenShop =
			    "<a> <span style='color:#C6B497'> <b> Tên shop: </b> </a>"
			        & CONCATENATEX( VALUES( 'DIM_Danh mục_Phòng ban'[Cửa hàng] ), 'DIM_Danh mục_Phòng ban'[Cửa hàng], ", " ) & "." 
			
			--Khác
			VAR zf_AM =
			    ISFILTERED( 'DIM_Danh mục_Phòng ban'[AM] )
			VAR zAM =
			    "<a> <span style='color:#C6B497'> <b> AM: </b> </a>"
			        & CONCATENATEX( VALUES( 'DIM_Danh mục_Phòng ban'[AM] ), 'DIM_Danh mục_Phòng ban'[AM], ", " ) & "."
			
			VAR zf_SM =
			    ISFILTERED( AM_SM_Current_Month[SM/SUP] )
			VAR zSM =
			    "<a> <span style='color:#C6B497'> <b> SM/SUP: </b> </a>"
			        & CONCATENATEX( VALUES( AM_SM_Current_Month[SM/SUP] ), AM_SM_Current_Month[SM/SUP], ", " ) & "."
			
			VAR zf_Size =
			    ISFILTERED( 'DIM_Danh mục_Phòng ban'[Size] )
			VAR zSize =
			    "<a> <span style='color:#C6B497'> <b> Size: </b> </a>"
			        & CONCATENATEX( VALUES( 'DIM_Danh mục_Phòng ban'[Size] ), 'DIM_Danh mục_Phòng ban'[Size], ", " ) & "."
			
			VAR zf_DanhGia =
			    ISFILTERED( 'DIM_Danh mục_Đánh giá'[Đánh giá] )
			VAR zDanhGia =
			    "<a> <span style='color:#C6B497'> <b> Kết quả đánh giá: </b> </a>"
			        & CONCATENATEX( VALUES( 'DIM_Danh mục_Đánh giá'[Đánh giá] ), 'DIM_Danh mục_Đánh giá'[Đánh giá], ", " ) & "."
			
			--Filter
			// VAR zf_ThoiGian =
			//     IF( 
			//         zf_NamThang = TRUE,
			//         1, 
			//         0 
			//     )
			VAR zf_DiaDiem =
			    IF(
			        zf_Mien = TRUE
			            || zf_TinhThanh = TRUE
			            || zf_TenShop = TRUE,
			        1,
			        0
			    )
			VAR zf_Khac =
			    IF(
			        zf_AM = TRUE
			            || zf_SM = TRUE
			            || zf_Size = TRUE
			            || zf_DanhGia = TRUE,
			        1,
			        0
			    )
			VAR zf_All =
			    IF( zf_DiaDiem + zf_Khac > 0, 1, 0 )
			VAR zFilter =
			    IF(
			        zf_All = 0,
			        BLANK(),
			        "<u> Bộ lọc áp dụng:</u>"
			            // & IF( zf_NamThang = TRUE, "<br>" & zNamThang, BLANK() )
			            & IF( zf_Mien = TRUE, "<br>" & zMien, BLANK() )
			            & IF( zf_TinhThanh = TRUE, "<br>" & zTinhThanh, BLANK() )          
			            & IF( zf_AM = TRUE, "<br>" & zAM, BLANK() )
			            & IF( zf_SM = TRUE, "<br>" & zSM, BLANK() )
			            & IF( zf_Size = TRUE, "<br>" & zSize, BLANK() )
			            & IF( zf_TenShop = TRUE, "<br>" & zTenShop, BLANK() )
			            & IF( zf_DanhGia = TRUE, "<br>" & zDanhGia, BLANK() )
			    )
			RETURN
			    "<i> <span style='color:white'>
			        <u> Cập nhật đến:</u>" & [Thời gian cập nhật] & "<br>" & zFilter
			    &  "</i>"
			```
		displayFolder: 1. Đánh giá Shop
		lineageTag: b4edeee3-7f6c-4b38-89f9-69ed09fdf914

