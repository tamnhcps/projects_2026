	measure 'Color Format' = ```
			
			VAR esl = SELECTEDVALUE('FACT_Đánh giá Shop'[% Target sử dụng ESL])
			VAR app = SELECTEDVALUE('FACT_Đánh giá Shop'[% Target lượt tải app])
			VAR nang_suat = SELECTEDVALUE('FACT_Đánh giá Shop'[% Target năng suất định biên])
			VAR dao_tao = SELECTEDVALUE('FACT_Đánh giá Shop'[% Target tham gia đào tạo])
			VAR khtn = SELECTEDVALUE('FACT_Đánh giá Shop'[% Target thu thập KHTN])
			VAR onl = SELECTEDVALUE('FACT_Đánh giá Shop'[% Target thành công đơn Online])
			VAR that_thoat = SELECTEDVALUE('FACT_Đánh giá Shop'[% Target thất thoát hàng hóa])
			VAR tre_don = SELECTEDVALUE('FACT_Đánh giá Shop'[% Target trễ đơn giao hàng])
			VAR turnover = SELECTEDVALUE('FACT_Đánh giá Shop'[% Target turnover rate])
			VAR smem = SELECTEDVALUE('FACT_Đánh giá Shop'[% Target tư vấn smember])
			VAR _value =
			COALESCE(esl, turnover, nang_suat, app, tre_don, onl, that_thoat, dao_tao, smem, khtn)
			RETURN
			SWITCH(
			    TRUE(),
			    _value >= 1, "#A3D9A5",
			    _value >= 0.8, "#FFDD99",
			    _value < 0.8, "#FF9999",
			    BLANK()
			)
			
			
			```
		displayFolder: 2. Chỉ tiêu
		lineageTag: dd318e6c-7229-4a4b-ada7-cca3a3173988

