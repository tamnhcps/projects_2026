		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure TurnoverRate =
			
			VAR _zMonth =
			    MAX ( 'DIM_Danh mục_Ngày'[Tháng] )
			VAR _zYear =
			    MAX ( 'DIM_Danh mục_Ngày'[Năm] )
			
			VAR _zEmployees =
			    CALCULATE ( [Nhân sự còn lại], 'DIM_Danh mục_Nhân viên'[IsIncludedInRate] = TRUE )
			
			VAR _zPrevEmployees =
			    CALCULATE (
			        [Nhân sự còn lại],
			        'DIM_Danh mục_Nhân viên'[IsIncludedInRate] = TRUE,
			        DATEADD ( 'DIM_Danh mục_Ngày'[Date], -1, MONTH )
			    )
			
			VAR _zBaseEmployees =
			    CALCULATE ( [Nhân sự còn lại], 'DIM_Danh mục_Nhân viên'[IsIncludedInRate] = TRUE )
			        - CALCULATE ( [Nhân sự mới], 'DIM_Danh mục_Nhân viên'[IsIncludedInRate] = TRUE )
			        + CALCULATE ( [Nhân sự rời đi], 'DIM_Danh mục_Nhân viên'[IsIncludedInRate] = TRUE )
			
			VAR _zAvgEmployees = ( _zEmployees + _zPrevEmployees ) / 2
			VAR _zAvgBaseEmployees = ( _zEmployees + _zBaseEmployees ) / 2
			
			-- Tính nhân sự rời đi có weighting theo loại nhân viên
			VAR _zWeightedLeavers =
			    SUMX (
			        FILTER ( 'DIM_Danh mục_Nhân viên', 'DIM_Danh mục_Nhân viên'[IsIncludedInRate] = TRUE ),
			        VAR _leavers = [Nhân sự rời đi]
			        VAR _weight =
			            SWITCH (
			                TRUE (),
			                'DIM_Danh mục_Nhân viên'[IsProbation] = "Thủ việc", 0.5,
			                1
			            )
			        RETURN _leavers * _weight
			    )
			
			-- Tính cho cả năm (nếu không lọc theo tháng)
			VAR _zReEmployees =
			    SUMX (
			        VALUES ( 'DIM_Danh mục_Ngày'[Tháng] ),
			        CALCULATE ( _zWeightedLeavers )
			    )
			
			VAR _zAvgReEmployees =
			    AVERAGEX (
			        VALUES ( 'DIM_Danh mục_Ngày'[Tháng] ),
			        CALCULATE ( [Nhân sự còn lại], 'DIM_Danh mục_Nhân viên'[IsIncludedInRate] = TRUE )
			    )
			
			RETURN
			    // IF (
			    //     HASONEVALUE ( 'DIM_Danh mục_Ngày'[Tháng] ),
			    //     IF (
			    //         _zYear = 2022 && _zMonth = 1,
			    //         MIN ( DIVIDE ( _zWeightedLeavers, _zAvgBaseEmployees, BLANK () ), 1 ),
			    //         MIN ( DIVIDE ( _zWeightedLeavers, _zAvgEmployees, BLANK () ), 1 )
			    //     ),
			    //     MIN ( DIVIDE ( _zReEmployees, _zAvgReEmployees ), 1 )
			    // )
			_zWeightedLeavers
		displayFolder: 2. Chỉ tiêu
		lineageTag: abe48741-7601-4498-a64b-2c935cc18498

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Dso_S-Star =
			
			var nhomchinh =
			CALCULATE (
			    [Dso+voucher],
			    FILTER (
			        'DIM_Danh mục_Nhóm hàng',
			        'DIM_Danh mục_Nhóm hàng'[Thi đua S-Star] = 1
			        && 'DIM_Danh mục_Nhóm hàng'[Hệ số thi đua phụ kiện] = BLANK()
			    ),
			    FILTER (
			        'FACT_Sale_Doanh số bán',
			        'FACT_Sale_Doanh số bán'[exp_S-Star] = BLANK()
			    )
			)
			var nhomphu =
			CALCULATE (
			    [Dso+voucher],
			    FILTER (
			        'DIM_Danh mục_Nhóm hàng',
			        'DIM_Danh mục_Nhóm hàng'[Thi đua S-Star] = 1
			        && 'DIM_Danh mục_Nhóm hàng'[Hệ số thi đua phụ kiện] = 0.3
			    ),
			    FILTER (
			        'FACT_Sale_Doanh số bán',
			        'FACT_Sale_Doanh số bán'[exp_S-Star] = BLANK()
			    )
			)
			return nhomchinh + nhomphu*0.3
		displayFolder: 2. Chỉ tiêu
		lineageTag: 8e69801f-3ec7-4d89-beb3-80488f5f2200

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Dso_S-Star_Base = ```
			
			SUMX(
			    FILTER(
			        'FACT_Sale_Doanh số bán',
			        'FACT_Sale_Doanh số bán'[exp_S-Star] = BLANK()
			        && ISBLANK(RELATED('D_Sản phẩm'[S-Star_exp]))
			        && NOT(ISBLANK('FACT_Sale_Doanh số bán'[Dso+Voucher]))
			    ),
			    VAR _ngayban = 'FACT_Sale_Doanh số bán'[Date]
			    VAR _store = 'FACT_Sale_Doanh số bán'[Shop]
			    VAR _nhomhang = 'FACT_Sale_Doanh số bán'[DMC3]
			
			    VAR _heso =
			        CALCULATE(
			            MAX('Heso_ThiDua'[he_so_thi_dua_phu_kien]),
			            FILTER(
			                'Heso_ThiDua',
			                'Heso_ThiDua'[ngay_bat_dau] <= _ngayban &&
			                'Heso_ThiDua'[ngay_ket_thuc] >= _ngayban &&
			                'Heso_ThiDua'[nhom_hang] = _nhomhang
			            )
			        )
			    RETURN 'FACT_Sale_Doanh số bán'[Dso+Voucher] * _heso
			)
			
			```
		displayFolder: 2. Chỉ tiêu
		lineageTag: 8e098e16-aefd-4068-a778-a86b688a470b

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Dso_S-Star %' = ```
			
			VAR dso_base_all = 
			    CALCULATE (
			        [Dso_S-Star_Base],
			        ALL ( 'DIM_Danh mục_Nhóm hàng' )
			    )
			RETURN 
			    DIVIDE (
			        [Dso_S-Star],
			        dso_base_all,
			        BLANK ()
			    )
			```
		displayFolder: 2. Chỉ tiêu
		lineageTag: af52dc0a-9724-41c8-9cb1-ab572eaecd7e

