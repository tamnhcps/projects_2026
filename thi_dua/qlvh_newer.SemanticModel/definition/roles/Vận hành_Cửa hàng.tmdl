role 'Vận hành_Cửa hàng'
	modelPermission: read

	tablePermission 'DIM_Danh mục_Ngày' = 'DIM_Danh mục_Ngày'[Date]>=LOOKUPVALUE('DIM_Phân quyền user'[Startdate],'DIM_Phân quyền user'[Mail],USERPRINCIPALNAME())

	tablePermission 'DIM_Danh mục_Phòng ban' = ```
			IF( 
			LOOKUPVALUE('DIM_Phân quyền user'[Title],'DIM_Phân quyền user'[Mail] ,USERPRINCIPALNAME()) = "SHOP", 
			[Cửa hàng] IN DISTINCT(
			    SELECTCOLUMNS(
			        FILTER(
			            ADDCOLUMNS(
			                CROSSJOIN(
			                    FILTER('DIM_Danh mục_Phòng ban','DIM_Danh mục_Phòng ban'[Cửa hàng] = LOOKUPVALUE('DIM_Phân quyền user'[Tên],'DIM_Phân quyền user'[Mail],USERPRINCIPALNAME())),'DIM_Phân quyền user'),
			                        "Path leader", PATHCONTAINS('DIM_Phân quyền user'[Path],'DIM_Danh mục_Phòng ban'[Cửa hàng])),[Path leader]),"Cửa hàng",'DIM_Phân quyền user'[Tên]))
			,True)
			```

	annotation PBI_Id = c567f6315bf3452e9c7f6c35e7a84fa8

