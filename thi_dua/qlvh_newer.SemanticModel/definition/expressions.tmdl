expression 'DIM_Danh mục_Sản phẩm_Web' =
		let
		    Source = Value.NativeQuery(GoogleBigQuery.Database([BillingProject="cellphones-data-platform"]){[Name="cellphones-data-platform"]}[Data], "---""dataset_id=6e97d189-0524-457d-bd6e-30d5e5ad63ad""#(lf)SELECT DISTINCT#(lf)    cpeMain.sku,#(lf)    CASE#(lf)        WHEN cpeParentName.value IS NOT NULL THEN#(lf)            cpeParentName.value#(lf)        ELSE#(lf)            cpeName.value#(lf)    END AS Name,#(lf)    CASE#(lf)        WHEN cpeMain.attribute_set_id = 10 THEN 'Dienthoai'#(lf)        WHEN cpeMain.attribute_set_id = 11 THEN 'MTB'#(lf)        WHEN cpeMain.attribute_set_id = 12 THEN 'PhuKien'#(lf)        WHEN cpeMain.attribute_set_id = 23 THEN 'Laptop'#(lf)        ELSE 'PhuKienMTB'#(lf)    END AS WebUrl,#(lf)    CASE#(lf)        WHEN cpeParentLink.value IS NULL THEN#(lf)            CONCAT('https://cellphones.com.vn/', cpeChildLink.value, '.html')#(lf)        ELSE#(lf)            CONCAT('https://cellphones.com.vn/', cpeParentLink.value, '.html')#(lf)    END AS product_url#(lf)FROM `cellphones-data-platform.cps_magento_mysql_dwh.catalog_product_entity` as cpeMain#(lf)    LEFT JOIN `cellphones-data-platform.cps_magento_mysql_dwh.catalog_product_super_link` AS psl#(lf)        ON psl.product_id = cpeMain.entity_id#(lf)    LEFT JOIN `cellphones-data-platform.cps_magento_mysql_dwh.catalog_product_entity_varchar` AS cpeParentLink#(lf)        ON cpeParentLink.entity_id = psl.parent_id#(lf)           AND cpeParentLink.attribute_id = 86#(lf)    LEFT JOIN `cellphones-data-platform.cps_magento_mysql_dwh.catalog_product_entity_varchar` AS cpeChildLink#(lf)        ON cpeChildLink.entity_id = cpeMain.entity_id#(lf)           AND cpeChildLink.attribute_id = 86#(lf)    LEFT JOIN `cellphones-data-platform.cps_magento_mysql_dwh.catalog_product_entity_varchar` AS cpeParentName#(lf)        ON cpeParentName.entity_id = cpeParentLink.entity_id#(lf)           AND cpeParentName.attribute_id = 60#(lf)    LEFT JOIN `cellphones-data-platform.cps_magento_mysql_dwh.catalog_product_entity_varchar` AS cpeName#(lf)        ON cpeName.entity_id = cpeMain.entity_id#(lf)           AND cpeName.attribute_id = 60#(lf)WHERE cpeMain.sku IS NOT NULL#(lf)      AND cpeMain.updated_at >= '2015-12-12'", null, [EnableFolding=true])
		in
		    Source
	lineageTag: 02adfe01-cd5b-41eb-9239-c08f911ac195
