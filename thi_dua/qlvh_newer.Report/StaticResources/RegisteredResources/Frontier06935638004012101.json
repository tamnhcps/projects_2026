{
  "name": "Frontier",
  "dataColors": [
    "#426871",
    "#D2B04C",
    "#A3623A",
    "#C25A3D",
    "#C39B6A",
    "#01526D",
    "#998F85",
    "#D2B04C"
  ],
  "background": "#FFFFFF",
  "foreground": "#252423",
  "tableAccent": "#426871",
  "good": "#1AAB40",
  "neutral": "#D9B300",
  "bad": "#D64554",
  "maximum": "#426871",
  "center": "#C25A3D",
  "minimum": "#D3F6FF",
  "null": "#FF7F48",
  "hyperlink": "#0078d4",
  "visitedHyperlink": "#0078d4",
  "textClasses": {
    "callout": {
      "fontFace": "'Segoe UI Semibold', wf_segoe-ui_semibold, helvetica, arial, sans-serif",
      "fontSize": 12
    },
    "title": {
      "fontFace": "'Segoe UI Semibold', wf_segoe-ui_semibold, helvetica, arial, sans-serif",
      "fontSize": 10
    },
    "header": {
      "fontFace": "'Segoe UI Semibold', wf_segoe-ui_semibold, helvetica, arial, sans-serif"
    },
    "label": {
      "fontFace": "'Segoe UI Semibold', wf_segoe-ui_semibold, helvetica, arial, sans-serif"
    }
  },
  "visualStyles": {
    "*": {
      "*": {
        "background": [
          {
            "color": {
              "solid": {
                "color": "#FFFFFF"
              }
            }
          }
        ],
        "outspacePane": [
          {
            "backgroundColor": {
              "solid": {
                "color": "#FFFFFF"
              }
            }
          }
        ],
        "filterCard": [
          {
            "$id": "Applied",
            "foregroundColor": {
              "solid": {
                "color": "#252423"
              }
            }
          },
          {
            "$id": "Available",
            "backgroundColor": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "transparency": 0
          }
        ]
      }
    },
    "slicer": {
      "*": {
        "items": [
          {
            "background": {
              "solid": {
                "color": "#F9F7F2"
              }
            }
          }
        ]
      }
    },
    "page": {
      "*": {
        "outspace": [
          {
            "color": {
              "solid": {
                "color": "#FFFFFF"
              }
            }
          }
        ],
        "background": [
          {
            "transparency": 0,
            "color": {
              "solid": {
                "color": "#FFFFFF"
              }
            }
          }
        ]
      }
    }
  },
  "backgroundLight": "#FFFFFF"
}