	partition 'F_Hàng hóa thất thoát' = m
		mode: import
		queryGroup: NLVH
		source =
				let
				    Source = Value.NativeQuery(GoogleBigQuery.Database([BillingProject="cellphones-data-platform"]){[Name="cellphones-data-platform"]}[Data], "---""dataset_id=2b76bd77-41ce-4653-ab13-2e7bfcab5770""#(lf)-- HCM#(lf)SELECT #(lf)  UPPER(endS.Code) AS `Mã kho`,#(lf)  ag.AutoCode AS `Số phiếu`,#(lf)  DATE(ag.CreateDate) AS `Ngày lập phiếu`,#(lf)  sp.Code AS `Mã hàng`,#(lf)  SUM(asbd.Quantity) AS SL#(lf)FROM cellphones-data-platform.cps_cdc_sep_hcm_dbo.Acc_General ag#(lf)INNER JOIN cellphones-data-platform.cps_cdc_sep_hcm_dbo.Acc_StoreBill asb ON asb.Id = ag.Id#(lf)INNER JOIN cellphones-data-platform.cps_cdc_sep_hcm_dbo.Acc_StoreBillDetail asbd ON asbd.StoreBillId = asb.Id#(lf)INNER JOIN cellphones-data-platform.cps_cdc_sep_hcm_dbo.ERP_Store endS ON endS.Id = asbd.OutputStoreId#(lf)INNER JOIN cellphones-data-platform.cps_cdc_sep_hcm_dbo.Shared_Product sp ON asbd.ProductId = sp.Id#(lf)WHERE 1=1#(lf)AND ag.ReplaceById IS NULL#(lf)AND ag.CreatedById = 246#(lf)AND LEFT(ag.AutoCode, 2) = 'X.'#(lf)AND asb.MethodId = 13#(lf)AND DATE(ag.CreateDate) >= DATE_TRUNC(DATE_SUB(CURRENT_DATE(), INTERVAL 12 MONTH), MONTH)#(lf)GROUP BY 1,2,3,4#(lf)#(lf)UNION ALL #(lf)#(lf)-- HN#(lf)SELECT #(lf)  UPPER(endS.Code) AS `Mã kho`,#(lf)  ag.AutoCode AS `Số phiếu`,#(lf)  DATE(ag.CreateDate) AS `Ngày lập phiếu`,#(lf)  sp.Code AS `Mã hàng`,#(lf)  SUM(asbd.Quantity) AS SL#(lf)FROM cellphones-data-platform.cps_cdc_sep_hn_dbo.Acc_General ag#(lf)INNER JOIN cellphones-data-platform.cps_cdc_sep_hn_dbo.Acc_StoreBill asb ON asb.Id = ag.Id#(lf)INNER JOIN cellphones-data-platform.cps_cdc_sep_hn_dbo.Acc_StoreBillDetail asbd ON asbd.StoreBillId = asb.Id#(lf)INNER JOIN cellphones-data-platform.cps_cdc_sep_hn_dbo.ERP_Store endS ON endS.Id = asbd.OutputStoreId#(lf)INNER JOIN cellphones-data-platform.cps_cdc_sep_hn_dbo.Shared_Product sp ON asbd.ProductId = sp.Id#(lf)WHERE 1=1#(lf)AND ag.ReplaceById IS NULL#(lf)AND ag.CreatedById = 246#(lf)AND LEFT(ag.AutoCode, 2) = 'X.'#(lf)AND asb.MethodId = 13#(lf)AND DATE(ag.CreateDate) >= DATE_TRUNC(DATE_SUB(CURRENT_DATE(), INTERVAL 12 MONTH), MONTH)#(lf)GROUP BY 1,2,3,4", null, [EnableFolding=true])
				in
				    Source

