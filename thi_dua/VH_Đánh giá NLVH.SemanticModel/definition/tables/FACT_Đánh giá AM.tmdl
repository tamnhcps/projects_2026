table 'FACT_Đánh giá AM'
	lineageTag: 0e5582cd-da57-4744-bad6-3b9c17879fa1

	column 'Đánh giá cuối cùng' = ```
			
			SWITCH(
			    TRUE(),
			    'FACT_Đánh giá AM'[Score] >= 1 && 'FACT_Đánh giá AM'[Tổng chỉ tiêu đạt] >= 9, "Xuất sắc tuyệt đối",
			    'FACT_Đánh giá AM'[Score] >= 0.8 && 'FACT_Đánh giá AM'[Tổng chỉ tiêu đạt] >= 7, "Tốt",
			    'FACT_Đánh giá AM'[Score] >= 0.7 && 'FACT_Đánh giá AM'[Tổng chỉ tiêu đạt] >= 5, "Khá",
			    'FACT_Đánh giá AM'[Score] >= 0.5 && 'FACT_Đánh giá AM'[Tổng chỉ tiêu đạt] >= 3, "Kém",
			    'FACT_Đánh giá AM'[Score] < 0.5 && 'FACT_Đánh giá AM'[Tổng chỉ tiêu đạt] < 3, "Cảnh cáo",
			    "Cảnh cáo"
			)
			
			```
		lineageTag: 863bb587-ef95-403f-a75e-35838d34e499
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

