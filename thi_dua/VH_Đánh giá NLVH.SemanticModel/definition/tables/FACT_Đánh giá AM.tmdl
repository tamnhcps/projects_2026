	column SMKN =
			
			LOOKUPVALUE('DIM_Danh mục_Shop_SMKN'[SMKN],
			'DIM_Danh mục_Shop_SMKN'[CuaHang_NamThang],'FACT_Đánh giá AM'[Cửa hàng_NamThang])
