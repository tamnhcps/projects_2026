	partition 'FACT_Đánh giá AM' = calculated
		mode: import
		source = ```
				
				VAR table_final =
				    SELECTCOLUMNS (
				        SUMMARIZE (
				            'Kết quả đánh giá Shop',
				            'Kết quả đánh giá Shop'[Miền],
				            'Kết quả đánh giá Shop'[Tháng],
				            'Kết quả đánh giá Shop'[AM],
				            'Kết quả đánh giá Shop'[Cửa hàng],
				            "Score_heso", AVERAGE('Kết quả đánh giá Shop'[Score_heso]),
				            "Tổng chỉ tiêu đạt_heso", ROUND(AVERAGE('Kết quả đánh giá Shop'[Tổng chỉ tiêu đạt_heso]),0)
				        ),
				        "MIỀN", [Miền],
				        "Tháng", [Tháng],
				        "AM", [AM],
				        "Cửa hàng", [Cửa hàng],
				        "Score", [Score_heso],
				        "Tổng chỉ tiêu đạt", [Tổng chỉ tiêu đạt_heso]
				    )
				
				VAR table_current =
				    SELECTCOLUMNS (
				        SUMMARIZE (
				            'FACT_Đánh giá Shop',
				            'FACT_Đánh giá Shop'[MIỀN],
				            'FACT_Đánh giá Shop'[StartDate],
				            'FACT_Đánh giá Shop'[AM],
				            'FACT_Đánh giá Shop'[SHOP],
				            "Score_heso", AVERAGE('FACT_Đánh giá Shop'[Score_heso]),
				            "Tổng chỉ tiêu đạt_heso", ROUND(AVERAGE('FACT_Đánh giá Shop'[Tổng chỉ tiêu đạt_heso]),0)
				        ),
				        "MIỀN", [MIỀN],
				        "Tháng", [StartDate],
				        "AM", [AM],
				        "Cửa hàng", [SHOP],
				        "Score", [Score_heso],
				        "Tổng chỉ tiêu đạt", [Tổng chỉ tiêu đạt_heso]
				    )
				
				RETURN
				UNION (table_current, table_final)
				
				```

	annotation PBI_Id = fe4d5306a0ef4d03b5352e2826b4b2f8

