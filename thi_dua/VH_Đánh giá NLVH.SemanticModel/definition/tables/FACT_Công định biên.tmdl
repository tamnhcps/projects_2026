table 'FACT_Công định biên'
	lineageTag: d8029299-6741-4eb2-946d-95634cdc9c55

	column StartDate
		formatString: General Date
		lineageTag: e5e96629-5b24-4c9c-87a0-3d92987ac144
		summarizeBy: none
		isNameInferred
		sourceColumn: FACT_Sale_Doanh số bán[StartDate]

		variation Variation
			isDefault
			relationship: 7cc0a10e-96d6-4e62-b162-b7b59972ecfb
			defaultHierarchy: LocalDateTable_badb1273-b41c-4b36-b059-ca9b902f697f.'Date Hierarchy'

		annotation SummarizationSetBy = Automatic

	column Dso
		lineageTag: ae091cec-438c-45f3-b93c-261db51000d5
		summarizeBy: sum
		isNameInferred
		sourceColumn: [Dso]

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column 'Last Date'
		formatString: General Date
		lineageTag: fd203314-997b-454b-b628-35cfdd9bce79
		summarizeBy: none
		isNameInferred
		sourceColumn: [Last Date]

		variation Variation
			isDefault
			relationship: 79c6e00a-13cf-4d99-8739-4c3e0b4c365c
			defaultHierarchy: LocalDateTable_9319905b-e445-49ed-99cf-72ed3e9074d7.'Date Hierarchy'

		annotation SummarizationSetBy = Automatic

	column 'Định biên_Năng suất' =
			
			var target = CALCULATE (
			    SUM (FACT_GSheet_Target_Shop_Daily[Target]),
			    FILTER (
			        FACT_GSheet_Target_Shop_Daily,
			        FACT_GSheet_Target_Shop_Daily[Type] = "DSO TARGET"
			            && 'FACT_GSheet_Target_Shop_Daily'[Object] = EARLIER( 'FACT_Công định biên'[Shop] )
			            && STARTOFMONTH('FACT_GSheet_Target_Shop_Daily'[Date]) = EARLIER('FACT_Công định biên'[StartDate])
			    )
			)
			return DIVIDE(target, 'FACT_Công định biên'[Định biên_Công])
		lineageTag: f8776729-c02c-46f7-a386-18a4b3b9330d
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column 'Định biên_Công' = ('FACT_Công định biên'[Số ngày trong tháng] - 4) * 8 * 'FACT_Công định biên'[Định biên_HC]
		lineageTag: 18c424b4-796b-44c4-a677-2f4adcb5ea11
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column 'Số ngày thực hiện'
		formatString: 0
		lineageTag: 94ba703d-067b-43fe-afe5-4200d1aedb3e
		summarizeBy: sum
		isNameInferred
		sourceColumn: [Số ngày thực hiện]

		annotation SummarizationSetBy = Automatic

	column 'Công thực tế'
		lineageTag: 8cd319a7-d04c-4dc5-8f97-01f704368450
		summarizeBy: sum
		isNameInferred
		sourceColumn: [Công thực tế]

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column 'Số ngày trong tháng'
		lineageTag: d5add6fa-b859-469e-8e36-41b90b7e5e70
		summarizeBy: sum
		isNameInferred
		sourceColumn: [Số ngày trong tháng]

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column 'Định biên_HC' = CALCULATE(VALUES(DinhBien[Định biên]), FILTER(DinhBien, DinhBien[StartDate] <= EARLIER('FACT_Công định biên'[StartDate]) && DinhBien[EndDate] > EARLIER('FACT_Công định biên'[StartDate]) && DinhBien[SHOP] = EARLIER('FACT_Công định biên'[Shop])))
		formatString: 0
		lineageTag: 232da44c-7c9c-4c85-a31c-bf34dda76d5c
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column Shop
		lineageTag: 43e235af-f502-4ef4-97f7-894b1b8bf0c4
		summarizeBy: none
		isNameInferred
		sourceColumn: FACT_Sale_Doanh số bán[Shop]

		annotation SummarizationSetBy = Automatic

	partition 'FACT_Công định biên' = calculated
		mode: import
		source =
				
				CALCULATETABLE(
				    SUMMARIZE(
				        'FACT_Sale_Doanh số bán',
				        'FACT_Sale_Doanh số bán'[Shop],
				        'FACT_Sale_Doanh số bán'[StartDate],
				        "Dso", [Dso],
				        "Công thực tế", [Công thực tế],
				        "Số ngày trong tháng", AVERAGE( 'FACT_Sale_Doanh số bán'[Số ngày trong tháng] ),
				        "Số ngày thực hiện", [Số ngày thực hiện],
				        "Last Date", LASTDATE('FACT_Sale_Doanh số bán'[Date])
				    ),
				    FILTER( 'FACT_Sale_Doanh số bán', 'FACT_Sale_Doanh số bán'[StoreCode] <> BLANK())
				)

	annotation PBI_Id = f1b8679f9bc04bc891a7328e46ff74e5

