	column 'Tỷ lệ sử dụng ESL' =
			
			VAR _shop = 'FACT_Đánh giá Shop'[SHOP]   -- measure trả về tên cửa hàng
			VAR _bgdt =
			CALCULATE(
			    AVERAGE(F_PriceTag[Count_MaChaWeb]),
			    FILTER(
			        F_PriceTag,
			        F_PriceTag[branchname] = _shop
			        && F_PriceTag[date] >= 'FACT_Đánh giá Shop'[StartDate]
			        && F_PriceTag[date] <= 'FACT_Đánh giá Shop'[MaxDate]
			    ))
			VAR _dinhbien =
			CALCULATE(
			    SUM('F_Định biên trưng bày'[ĐỊNH BIÊN TRƯNG BÀY]),
			    FILTER(
			        'F_Định biên trưng bày',
			        'F_Định biên trưng bày'[MÃ SHOP] = _shop
			    )
			)
			RETURN
			MIN(DIVIDE(_bgdt,_dinhbien), 1)
		formatString: #,0.00%;-#,0.00%;#,0.00%
