	column 'Đánh giá cuối cùng' = ```
			
			SWITCH(
			    TRUE(),
			    'FACT_Đánh giá Shop'[Score] >= 1 && 'FACT_Đánh giá Shop'[Tổng chỉ tiêu đạt] >= 9, "Xuất sắc tuyệt đối",
			    'FACT_Đánh giá Shop'[Score] >= 0.8 && 'FACT_Đánh giá Shop'[Tổng chỉ tiêu đạt] >= 7, "Tốt",
			    'FACT_Đánh giá Shop'[Score] >= 0.7 && 'FACT_Đánh giá Shop'[Tổng chỉ tiêu đạt] >= 5, "Khá",
			    'FACT_Đánh giá Shop'[Score] >= 0.5 && 'FACT_Đánh giá Shop'[Tổng chỉ tiêu đạt] >= 3, "Kém",
			    'FACT_Đánh giá Shop'[Score] < 0.5 && 'FACT_Đánh giá Shop'[Tổng chỉ tiêu đạt] < 3, "Cảnh cáo",
			    "Cảnh cáo"
			)
			
			```
		lineageTag: 93691d7c-c999-45ca-84be-a076bfd69757
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Xếp hạng cửa hàng' =
			
			RANKX(
			    FILTER(
			        'FACT_Đánh giá Shop',
			        'FACT_Đánh giá Shop'[StartDate]
			            = EARLIER( 'FACT_Đánh giá Shop'[StartDate] )
			            && 'FACT_Đánh giá Shop'[MIỀN]
			            = EARLIER( 'FACT_Đánh giá Shop'[MIỀN] )
			            && 'FACT_Đánh giá Shop'[Đánh giá cuối cùng]
			            = EARLIER( 'FACT_Đánh giá Shop'[Đánh giá cuối cùng] )
			    ),
			    'FACT_Đánh giá Shop'[Score],
			    [Score],
			    DESC,
			    DENSE
			)
		formatString: 0
		lineageTag: 4d9e5857-3223-4b5c-bb43-ba4650a59052
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column 'Xếp hạng cuối cùng' =
			
			VAR max_xuatsac =
			CALCULATE(
			    DISTINCTCOUNT( 'FACT_Đánh giá Shop'[SHOP] ),
			    FILTER(
			        'FACT_Đánh giá Shop',
			            'FACT_Đánh giá Shop'[MIỀN] = EARLIER( 'FACT_Đánh giá Shop'[MIỀN] )
			            && 'FACT_Đánh giá Shop'[StartDate] = EARLIER( 'FACT_Đánh giá Shop'[StartDate] )
			            && 'FACT_Đánh giá Shop'[Đánh giá cuối cùng] = "Xuất sắc tuyệt đối"
			    )
			)
			VAR max_tot =
			CALCULATE(
			    DISTINCTCOUNT( 'FACT_Đánh giá Shop'[SHOP] ),
			    FILTER(
			        'FACT_Đánh giá Shop',
			            'FACT_Đánh giá Shop'[MIỀN] = EARLIER( 'FACT_Đánh giá Shop'[MIỀN] )
			            && 'FACT_Đánh giá Shop'[StartDate] = EARLIER( 'FACT_Đánh giá Shop'[StartDate] )
			            && 'FACT_Đánh giá Shop'[Đánh giá cuối cùng] = "Tốt"
			    )
			)
			VAR max_kha =
			CALCULATE(
			    DISTINCTCOUNT( 'FACT_Đánh giá Shop'[SHOP] ),
			    FILTER(
			        'FACT_Đánh giá Shop',
			            'FACT_Đánh giá Shop'[MIỀN] = EARLIER( 'FACT_Đánh giá Shop'[MIỀN] )
			            && 'FACT_Đánh giá Shop'[StartDate] = EARLIER( 'FACT_Đánh giá Shop'[StartDate] )
			            && 'FACT_Đánh giá Shop'[Đánh giá cuối cùng] = "Khá"
			    )
			)
			VAR max_kem =
			CALCULATE(
			    DISTINCTCOUNT( 'FACT_Đánh giá Shop'[SHOP] ),
			    FILTER(
			        'FACT_Đánh giá Shop',
			            'FACT_Đánh giá Shop'[MIỀN] = EARLIER( 'FACT_Đánh giá Shop'[MIỀN] )
			            && 'FACT_Đánh giá Shop'[StartDate] = EARLIER( 'FACT_Đánh giá Shop'[StartDate] )
			            && 'FACT_Đánh giá Shop'[Đánh giá cuối cùng] = "Kém"
			    )
			)
			
			RETURN SWITCH(TRUE(),
			'FACT_Đánh giá Shop'[Đánh giá cuối cùng] = "Tốt",'FACT_Đánh giá Shop'[Xếp hạng cửa hàng]+max_xuatsac,
			'FACT_Đánh giá Shop'[Đánh giá cuối cùng] = "Khá",'FACT_Đánh giá Shop'[Xếp hạng cửa hàng]+max_tot+max_xuatsac,
			'FACT_Đánh giá Shop'[Đánh giá cuối cùng] = "Kém",'FACT_Đánh giá Shop'[Xếp hạng cửa hàng]+max_tot+max_xuatsac+max_kha,
			'FACT_Đánh giá Shop'[Đánh giá cuối cùng] = "Cảnh cáo",'FACT_Đánh giá Shop'[Xếp hạng cửa hàng]+max_tot+max_xuatsac+max_kha+max_kem,'FACT_Đánh giá Shop'[Xếp hạng cửa hàng])
		formatString: 0
		lineageTag: e3845c79-8ad2-45e8-8022-1a43e3c4df18
		summarizeBy: sum

