	column Score =
			
			VAR esl = 'FACT_Đánh giá Shop'[% Target sử dụng ESL]
			VAR app = 'FACT_Đánh giá Shop'[% Target lượt tải app]
			VAR nang_suat = 'FACT_Đánh giá Shop'[% Target năng suất định biên]
			VAR dao_tao = 'FACT_Đánh giá Shop'[% Target tham gia đào tạo]
			VAR khtn = 'FACT_Đánh giá Shop'[% Target thu thập KHTN]
			VAR onl = 'FACT_Đánh giá Shop'[% Target thành công đơn Online]
			VAR that_thoat = 'FACT_Đánh giá Shop'[% Target thất thoát hàng hóa]
			VAR tre_don = 'FACT_Đánh giá Shop'[% Target trễ đơn giao hàng]
			VAR turnover = 'FACT_Đánh giá Shop'[% Target turnover rate]
			VAR smem = 'FACT_Đánh giá Shop'[% Target tư vấn smember]
			VAR _result =
			0.15*(esl + turnover + nang_suat) + 0.1*(app + tre_don + onl + that_thoat) + 0.05*(dao_tao + smem + khtn)
			RETURN _result
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 81041bc1-9759-4081-91ab-d63de2384bca
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column 'Tổng chỉ tiêu đạt' = ```
			
			VAR esl = IF('FACT_Đánh giá Shop'[% Target sử dụng ESL] >= 1,1,0)
			VAR app = IF('FACT_Đánh giá Shop'[% Target lượt tải app] >= 1,1,0)
			VAR nang_suat = IF('FACT_Đánh giá Shop'[% Target năng suất định biên] >= 1,1,0)
			VAR dao_tao = IF('FACT_Đánh giá Shop'[% Target tham gia đào tạo] >= 1,1,0)
			VAR khtn = IF('FACT_Đánh giá Shop'[% Target thu thập KHTN] >= 1,1,0)
			VAR onl = IF('FACT_Đánh giá Shop'[% Target thành công đơn Online] >= 1,1,0)
			VAR that_thoat = IF('FACT_Đánh giá Shop'[% Target thất thoát hàng hóa] >= 1,1,0)
			VAR tre_don = IF('FACT_Đánh giá Shop'[% Target trễ đơn giao hàng] >= 1,1,0)
			VAR turnover = IF('FACT_Đánh giá Shop'[% Target turnover rate] >= 1,1,0)
			VAR smem = IF('FACT_Đánh giá Shop'[% Target tư vấn smember] >= 1,1,0)
			VAR _result =
			1*(esl + turnover + nang_suat) + 1*(app + tre_don + onl + that_thoat) + 1*(dao_tao + smem + khtn)
			RETURN _result
			
			```
		formatString: 0
		lineageTag: 4a8ab85e-122d-41cb-ad33-31202ffe5474
		summarizeBy: sum

