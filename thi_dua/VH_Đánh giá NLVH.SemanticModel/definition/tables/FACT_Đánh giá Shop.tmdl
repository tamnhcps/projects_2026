table 'FACT_Đánh giá Shop'
	lineageTag: cbc017b7-f655-47aa-9db5-dc91e11d685c

	column Runrate =
			
			VAR SoNgay =
			    CALCULATE(
			        COUNT( 'DIM_Danh mục_Ngày'[Date] ),
			        FILTER(
			            'DIM_Danh mục_Ngày',
			            'DIM_Danh mục_Ngày'[Đầu tháng]
			                = EARLIER( 'FACT_Đánh giá Shop'[StartDate] )
			        )
			    )
			VAR SoNgayThucHien =
			    CALCULATE(
			        COUNT( 'DIM_Danh mục_Ngày'[Date] ),
			        FILTER(
			            'DIM_Danh mục_Ngày',
			            'DIM_Danh mục_Ngày'[Ngày_IsActive] = 1
			                && 'DIM_Danh mục_Ngày'[Đầu tháng]
			                    = EARLIER( 'FACT_Đánh giá Shop'[StartDate] )
			        )
			    )
			RETURN MAX(DIVIDE(SoNgay,SoNgayThucHien,0),1)
		lineageTag: b4dc1e42-966d-400b-ab97-5fb3697c00a7
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column Dso =
			
			CALCULATE(
			    SUM( 'FACT_Sale_Doanh số bán'[Dso] ),
			    FILTER(
			        'FACT_Sale_Doanh số bán',
			        'FACT_Sale_Doanh số bán'[Shop]
			            = EARLIER( 'FACT_Đánh giá Shop'[SHOP] )
			            && 'FACT_Sale_Doanh số bán'[Date]
			                >= ( 'FACT_Đánh giá Shop'[StartDate] )
			            && 'FACT_Sale_Doanh số bán'[Date]
			                <= ( 'FACT_Đánh giá Shop'[MaxDate] )
			            && 'FACT_Sale_Doanh số bán'[Check online+B2B] = 0
			    )
			)
		formatString: #,0
		lineageTag: fe332293-628e-4f7a-b062-b7e4fd2c62dd
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isDecimal":true}

	column 'Tỷ lệ trễ đơn giao hàng' = ```
			
			VAR _shop = 'FACT_Đánh giá Shop'[SHOP]
			VAR _startdate = 'FACT_Đánh giá Shop'[StartDate]
			VAR _maxdate = 'FACT_Đánh giá Shop'[MaxDate]
			VAR tre_han_DH = 
			CALCULATE (
			    COUNT('F_Logistics'[Trễ hạn_DH] ),
			    FILTER (
			        'F_Logistics',
			        'F_Logistics'[Trễ hạn_DH]= "Trễ hạn"
			        && F_Logistics[Cửa hàng] = _shop
			        && F_Logistics[Ngày tạo chuyến đi].[Date] >= _startdate
			        && F_Logistics[Ngày tạo chuyến đi].[Date] <= _maxdate
			    )
			)
			VAR tong_phan_loai = 
			CALCULATE (
			    COUNT('F_Logistics'[Trễ hạn_DH] ),
			    FILTER (
			        'F_Logistics',
			        'F_Logistics'[Trễ hạn_DH] <> BLANK()
			        && F_Logistics[Cửa hàng] = _shop
			        && F_Logistics[Ngày tạo chuyến đi].[Date] >= _startdate
			        && F_Logistics[Ngày tạo chuyến đi].[Date] <= _maxdate
			    )
			)
			RETURN
			DIVIDE(tre_han_DH,tong_phan_loai,BLANK())
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 23a0d139-fd29-4278-ae30-cbb0f3b20319
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column 'Tỷ lệ năng suất định biên' = ```
			
			VAR _shop = 'FACT_Đánh giá Shop'[SHOP]
			VAR _startdate = 'FACT_Đánh giá Shop'[StartDate]
			VAR cong = 
			CALCULATE(
			    SUM( 'F_Công chi tiết'[Tổng giờ] ),
			    FILTER(
			        'F_Công chi tiết',
			        'F_Công chi tiết'[Vị trí mới] <> BLANK()
			            && 'F_Công chi tiết'[Vị trí mới] <> "PG"
			            && 'F_Công chi tiết'[Vị trí mới] <> "Tiếp đón"
			            && 'F_Công chi tiết'[IsHocviec] = "Không"
			            && 'F_Công chi tiết'[Phòng ban] = _shop
			            && 'F_Công chi tiết'[Date]
			                >= ( 'FACT_Đánh giá Shop'[StartDate] )
			            && 'F_Công chi tiết'[Date]
			                <= ( 'FACT_Đánh giá Shop'[MaxDate] )
			    )
			)
			VAR dso = 
			'FACT_Đánh giá Shop'[Dso]
			VAR nang_suat = DIVIDE(dso,cong)
			VAR target = 
			CALCULATE(
			    AVERAGE('FACT_Công định biên'[Định biên_Năng suất]),
			    FILTER(
			        'FACT_Công định biên',
			        'FACT_Công định biên'[Shop]
			            = EARLIER( 'FACT_Đánh giá Shop'[SHOP] )
			            && 'FACT_Công định biên'[StartDate] = EARLIER('FACT_Đánh giá Shop'[StartDate])
			    )
			)
			RETURN
			DIVIDE(nang_suat,target)
			```
		lineageTag: 780bdee0-f428-4b08-8d63-cc86466a5b3d
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column 'Tỷ lệ tư vấn smember' = ```
			
			VAR _shop = 'FACT_Đánh giá Shop'[SHOP]
			VAR _startdate = 'FACT_Đánh giá Shop'[StartDate]
			VAR _maxdate = 'FACT_Đánh giá Shop'[MaxDate]
			VAR co_tu_van = 
			CALCULATE (
			    SUM('F_Combined_Metric_CS'[so_luong_phieu_co_tu_van] ),
			    FILTER (
			        'F_Combined_Metric_CS',
			        F_Combined_Metric_CS[bo_phan] = _shop
			        && F_Combined_Metric_CS[Date] >= _startdate
			        && F_Combined_Metric_CS[Date] <= _maxdate
			    )
			)
			VAR tu_van = 
			CALCULATE (
			    SUM('F_Combined_Metric_CS'[so_luong_phieu_tu_van] ),
			    FILTER (
			        'F_Combined_Metric_CS',
			        F_Combined_Metric_CS[bo_phan] = _shop
			        && F_Combined_Metric_CS[Date] >= _startdate
			        && F_Combined_Metric_CS[Date] <= _maxdate
			    )
			)
			RETURN
			DIVIDE(co_tu_van,tu_van,BLANK())
			```
		lineageTag: 6176e364-2bc5-40ac-bd19-04cfbcbc53d9
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column 'Tỷ lệ thu thập KHTN' =
			
			VAR khtn_customer =
			    CALCULATE(
			        SUM( F_Combined_Metric_CS[khtn_customer] ),
			        FILTER(
			            F_Combined_Metric_CS,
			            F_Combined_Metric_CS[bo_phan]
			                = EARLIER( 'FACT_Đánh giá Shop'[SHOP] )
			                && F_Combined_Metric_CS[date] >= ( 'FACT_Đánh giá Shop'[StartDate] )
			                && F_Combined_Metric_CS[date] <= ( 'FACT_Đánh giá Shop'[MaxDate] )
			        )
			    )
			VAR Target_daily =
			    CALCULATE(
			        SUM( F_Combined_Metric_CS[target_daily_khtn] ),
			        FILTER(
			            F_Combined_Metric_CS,
			            F_Combined_Metric_CS[bo_phan]
			                = EARLIER( 'FACT_Đánh giá Shop'[SHOP] )
			                && F_Combined_Metric_CS[date] >= ( 'FACT_Đánh giá Shop'[StartDate] )
			                && F_Combined_Metric_CS[date] <= ( 'FACT_Đánh giá Shop'[MaxDate] )
			        )
			    )
			RETURN
			MIN(DIVIDE(khtn_customer,Target_daily), 1)
		lineageTag: 1af0bb73-b69e-408c-af61-6943b92cb2eb
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

