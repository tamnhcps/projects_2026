	column 'Tỷ lệ lượt tải app' = ```
			
			VAR luot_tai_app =
			    CALCULATE(
			        SUM( F_Combined_Metric_CS[luot_tai_app] ),
			        FILTER(
			            F_Combined_Metric_CS,
			            F_Combined_Metric_CS[bo_phan]
			                = EARLIER( 'FACT_Đánh giá Shop'[SHOP] )
			                && F_Combined_Metric_CS[date] >= ( 'FACT_Đánh giá Shop'[StartDate] )
			                && F_Combined_Metric_CS[date] <= ( 'FACT_Đánh giá Shop'[MaxDate] )
			                && NOT (
			                F_Combined_Metric_CS[date] >= DATE(2025,10,09)
			                && F_Combined_Metric_CS[date] <= DATE(2025,10,15))        
			        )
			    )
			VAR chua_co_app =
			    CALCULATE(
			        SUM( F_Combined_Metric_CS[chua_co_app] ),
			        FILTER(
			            F_Combined_Metric_CS,
			            F_Combined_Metric_CS[bo_phan]
			                = EARLIER( 'FACT_Đánh giá Shop'[SHOP] )
			                && F_Combined_Metric_CS[date] >= ( 'FACT_Đánh giá Shop'[StartDate] )
			                && F_Combined_Metric_CS[date] <= ( 'FACT_Đánh giá Shop'[MaxDate] )
			                && NOT (
			                F_Combined_Metric_CS[date] >= DATE(2025,10,09)
			                && F_Combined_Metric_CS[date] <= DATE(2025,10,15))        
			        )
			    )
			RETURN
			MIN(DIVIDE(luot_tai_app,chua_co_app), 1)
			```
		lineageTag: 388306c8-ea8d-4240-b89d-d407cebd0b48
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column 'Tổng chỉ tiêu đạt_heso' = ```
			
			VAR 
			_z = 
			DIVIDE (
			    SUMX (
			        FILTER (
			            'FACT_Đánh giá Shop',
			            'FACT_Đánh giá Shop'[Miền] = EARLIER('FACT_Đánh giá Shop'[Miền]) &&
			            'FACT_Đánh giá Shop'[StartDate] = EARLIER('FACT_Đánh giá Shop'[StartDate]) &&
			            'FACT_Đánh giá Shop'[AM_DIM] = EARLIER('FACT_Đánh giá Shop'[AM_DIM])
			        ),
			        'FACT_Đánh giá Shop'[Tổng chỉ tiêu đạt] * 'FACT_Đánh giá Shop'[Điểm quy đổi]
			    ),
			    SUMX (
			        FILTER (
			            'FACT_Đánh giá Shop',
			            'FACT_Đánh giá Shop'[Miền] = EARLIER('FACT_Đánh giá Shop'[Miền]) &&
			            'FACT_Đánh giá Shop'[StartDate] = EARLIER('FACT_Đánh giá Shop'[StartDate]) &&
			            'FACT_Đánh giá Shop'[AM_DIM] = EARLIER('FACT_Đánh giá Shop'[AM_DIM])
			        ),
			        'FACT_Đánh giá Shop'[Điểm quy đổi]
			    )
			)
			RETURN
			ROUND(_z,0)
			```
		lineageTag: ee21385c-51fd-472c-8697-e09fbf50eaf2
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column 'Tỷ lệ turnover rate' =
			
			VAR _shop =
			    ('FACT_Đánh giá Shop'[SHOP])
			VAR _startdate =
			    ('FACT_Đánh giá Shop'[StartDate])
			VAR _maxdate =
			    ('FACT_Đánh giá Shop'[MaxDate])
			
			-- Nhân sự còn lại đầu kỳ
			RETURN
			CALCULATE(
			    [TurnoverRate],
			    FILTER(
			        'DIM_Danh mục_Phòng ban',
			        'DIM_Danh mục_Phòng ban'[Cửa hàng] = _shop),
			    FILTER(
			        'DIM_Danh mục_Ngày',
			        'DIM_Danh mục_Ngày'[Date] >= _startdate
			        && 'DIM_Danh mục_Ngày'[Date] <= _maxdate
			    )
			)
		formatString: 0.00
		lineageTag: 86226a94-706c-4c19-b753-803d062c4fe6
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column 'Tỷ lệ thất thoát hàng hóa' = ```
			
			VAR _shop = 'FACT_Đánh giá Shop'[SHOP]
			VAR _startdate = 'FACT_Đánh giá Shop'[StartDate]
			VAR _maxdate = 'FACT_Đánh giá Shop'[MaxDate]
			var Stien = 
			    CALCULATE(
			        SUM('F_Xử lý hàng hóa'[Số tiền]),
			        FILTER(
			            'F_Xử lý hàng hóa',
			            'F_Xử lý hàng hóa'[Cửa hàng] = _shop
			            && 'F_Xử lý hàng hóa'[Ngày kiểm kê]
			                >= _startdate
			            && 'F_Xử lý hàng hóa'[Ngày kiểm kê]
			                <= _maxdate
			        )
			    )
			var Dso =
			'FACT_Đánh giá Shop'[Dso]
			return 
			DIVIDE(Stien, Dso, BLANK())
			```
		formatString: #,0
		lineageTag: da5afba0-3b2d-41da-9760-5ad37d660924
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isDecimal":true}

	column 'Target Dso' = ```
			
			VAR _Shop = ('FACT_Đánh giá Shop'[SHOP])
			VAR _StartDate = ('FACT_Đánh giá Shop'[StartDate])
			VAR _MaxDate = ('FACT_Đánh giá Shop'[MaxDate])
			
			VAR target =
			    CALCULATE (
			        SUM ( 'FACT_GSheet_Target_Shop_Daily'[Target] ),
			        FILTER(
			            FACT_GSheet_Target_Shop_Daily,
			            'FACT_GSheet_Target_Shop_Daily'[Type] = "DSO TARGET"
			            && 'FACT_GSheet_Target_Shop_Daily'[Object] = _Shop
			            && 'FACT_GSheet_Target_Shop_Daily'[Date] >= _StartDate
			            && 'FACT_GSheet_Target_Shop_Daily'[Date] <= _MaxDate
			    )
			    )
			VAR dso_iP17 =
			    CALCULATE (
			        [Dso],
			        FILTER (
			            'FACT_Sale_Doanh số bán',
			            CONTAINSSTRING ( 'FACT_Sale_Doanh số bán'[ProductCode], "APP-IP17" )
			            || CONTAINSSTRING ( 'FACT_Sale_Doanh số bán'[ProductCode], "APP-IP-AIR" )
			        ),
			        'FACT_Sale_Doanh số bán'[Date] >= DATE (2025, 9, 19),
			        'FACT_Sale_Doanh số bán'[Date] <= DATE (2025, 9, 24),
			        'FACT_Sale_Doanh số bán'[Shop] = _Shop,
			        'FACT_Sale_Doanh số bán'[Date] >= _StartDate,
			        'FACT_Sale_Doanh số bán'[Date] <= _MaxDate
			    )
			
			RETURN
			    target + dso_iP17
			
			```
		formatString: #,0.00
		lineageTag: e9cee522-c1e1-49ee-a4b1-62c95fb7f132
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column 'Target tư vấn smember' =
			
			CALCULATE(
			    AVERAGE(FACT_GSheet_Target_App[Target]),
			    FILTER(
			        FACT_GSheet_Target_App,
			        FACT_GSheet_Target_App[Miền]
			            = EARLIER( 'FACT_Đánh giá Shop'[MIỀN] )
			            && YEAR(FACT_GSheet_Target_App[Ngày bắt đầu]) = YEAR('FACT_Đánh giá Shop'[StartDate])
			            && MONTH(FACT_GSheet_Target_App[Ngày bắt đầu]) = MONTH('FACT_Đánh giá Shop'[StartDate])
			    )
			)
		formatString: 0.00%;-0.00%;0.00%
