	column no_day_fail = ```
			
			VAR CurrentShop = 'FACT_Đánh giá Shop'[SHOP]
			VAR CurrentStart = 'FACT_Đánh giá Shop'[StartDate]
			
			-- Tìm ngày mới nhất có đánh giá 
			VAR MaxDate =
			    CALCULATE(
			        MAX(FACT_Log_Ranking[Date]),
			        FILTER(
			            FACT_Log_Ranking,
			            'FACT_Log_Ranking'[Shop] = CurrentShop &&
			            STARTOFMONTH('FACT_Log_Ranking'[Date]) = CurrentStart
			        )
			    )
			
			-- Lấy bảng gồm tất cả các ngày 
			VAR AllDays =
			    FILTER(
			        FACT_Log_Ranking,
			        FACT_Log_Ranking[Shop] = CurrentShop &&
			        STARTOFMONTH('FACT_Log_Ranking'[Date]) = CurrentStart &&
			        FACT_Log_Ranking[Date] <= MaxDate
			    )
			
			-- Sắp xếp theo ngày giảm dần
			VAR SortedDays =
			    ADDCOLUMNS(
			        AllDays,
			        "Rank",
			        RANKX(
			            AllDays,
			            FACT_Log_Ranking[Date],
			            ,
			            DESC
			        )
			    )
			
			-- Duyệt từng ngày từ mới nhất → cũ, đếm bao nhiêu ngày liên tiếp không đạt (dừng khi gặp ngày đạt)
			VAR ConsecutiveBadDays =
			    COUNTROWS(
			        FILTER(
			            SortedDays,
			            VAR CurrentRank = [Rank]
			            RETURN
			                -- Lấy điểm của các ngày trước theo thứ tự
			                CALCULATE (
			                    MIN(FACT_Log_Ranking[Score]),
			                    FILTER (
			                        SortedDays,
			                        [Rank] <= CurrentRank
			                    )
			                ) < 1
			                &&
			                -- Không có ngày đạt nào phía trước
			                CALCULATE (
			                    MAX(FACT_Log_Ranking[Score]),
			                    FILTER (
			                        SortedDays,
			                        [Rank] < CurrentRank
			                    )
			                ) < 1
			        )
			    )
			
			RETURN
			ConsecutiveBadDays
			
			```
		formatString: 0
		lineageTag: fe620b50-62b9-48ba-9fac-a6efed836409
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

