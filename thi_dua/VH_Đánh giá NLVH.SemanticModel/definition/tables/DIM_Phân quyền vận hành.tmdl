	column OP =
			
			VAR Mien =
			    LOOKUPVALUE(
			        'DIM_Danh mục_Kho'[Miền],
			        'DIM_Danh mục_Kho'[Mã kho], 'DIM_Phân quyền vận hành'[Mã kho]
			    )
			RETURN
			    LOOKUPVALUE( 'DIM_Phân quyền vận hành_Vùng'[Tên],'DIM_Phân quyền vận hành_Vùng'[Miền],Mien)
		lineageTag: fe019dd3-b3fc-45ea-9f2c-d7cc3848ebfd
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column Leader = LOOKUPVALUE('DIM_Phân quyền user'[Leader],'DIM_Phân quyền user'[Tên],'DIM_Phân quyền vận hành'[Cửa hàng],BLANK())
		lineageTag: 830c0eed-ce4f-49fe-ac35-cef45f5609b1
