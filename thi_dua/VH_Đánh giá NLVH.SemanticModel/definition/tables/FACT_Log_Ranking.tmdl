	column 'Tỷ lệ tham gia đào tạo' = ```
			
			VAR _shop = 'FACT_Log_Ranking'[SHOP]
			VAR _startdate = STARTOFMONTH('FACT_Log_Ranking'[Date])
			VAR _maxdate = 'FACT_Log_Ranking'[MaxDate]
			VAR Current_Month = 
			    CALCULATE(
			        AVERAGE('F_Tham gia đào tạo'[Tỉ lệ tham gia]),
			        FILTER(
			            'F_Tham gia đào tạo',
			            'F_Tham gia đào tạo'[SHOP] = _shop
			            && 'F_Tham gia đào tạo'[StartDate] = _startdate
			        )
			    )
			
			RETURN
			    Current_Month
