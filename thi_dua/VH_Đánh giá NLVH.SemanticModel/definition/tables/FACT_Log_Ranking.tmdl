	column Ranking =
			
			RANKX(
			    FILTER(
			        'FACT_Log_Ranking',
			        'FACT_Log_Ranking'[Date]
			            = EARLIER( 'FACT_Log_Ranking'[Date] )
			            && 'FACT_Log_Ranking'[MIỀN]
			            = EARLIER( 'FACT_Log_Ranking'[MIỀN] )
			    ),
			    'FACT_Log_Ranking'[Score],
			    [Score],
			    DESC,
			    DENSE
			)
		formatString: 0
		lineageTag: 4e7aca2e-57ea-4d5d-92e7-f892e0935693
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column Runrate =
			
			VAR SoNgay =
			    CALCULATE(
			        COUNT( 'DIM_Danh mục_Ngày'[Date] ),
			        FILTER(
			            'DIM_Danh mục_Ngày',
			            'DIM_Danh mục_Ngày'[Đầu tháng]
			                = EARLIER( 'FACT_Log_Ranking'[Date] )
			        )
			    )
			VAR SoNgayThucHien =
			    CALCULATE(
			        COUNT( 'DIM_Danh mục_Ngày'[Date] ),
			        FILTER(
			            'DIM_Danh mục_Ngày',
			            'DIM_Danh mục_Ngày'[Ngày_IsActive] = 1
			                && 'DIM_Danh mục_Ngày'[Đầu tháng]
			                    = EARLIER( 'FACT_Log_Ranking'[Date] )
			        )
			    )
			RETURN MAX(DIVIDE(SoNgay,SoNgayThucHien,0),1)
		lineageTag: 54972835-1f13-41c0-b898-848990652167
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column Score =
			
			VAR esl = 'FACT_Log_Ranking'[% Target sử dụng ESL]
			VAR app = 'FACT_Log_Ranking'[% Target lượt tải app]
			VAR nang_suat = 'FACT_Log_Ranking'[% Target năng suất định biên]
			VAR dao_tao = 'FACT_Log_Ranking'[% Target tham gia đào tạo]
			VAR khtn = 'FACT_Log_Ranking'[% Target thu thập KHTN]
			VAR onl = 'FACT_Log_Ranking'[% Target thành công đơn Online]
			VAR that_thoat = 'FACT_Log_Ranking'[% Target thất thoát hàng hóa]
			VAR tre_don = 'FACT_Log_Ranking'[% Target trễ đơn giao hàng]
			VAR turnover = 'FACT_Log_Ranking'[% Target turnover rate]
			VAR smem = 'FACT_Log_Ranking'[% Target tư vấn smember]
			VAR _result =
			0.15*(esl + turnover + nang_suat) + 0.1*(app + tre_don + onl + that_thoat) + 0.05*(dao_tao + smem + khtn)
			RETURN _result
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 556a7508-7674-4046-bd93-5bd23f8ae803
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column Size = RELATED('DIM_Danh mục_Phòng ban'[Size])
		lineageTag: b09ecd77-499c-4c0b-854d-9410f3e244b2
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Target Dso' = ```
			
			VAR _Shop = ('FACT_Log_Ranking'[SHOP])
			VAR _StartDate = ('FACT_Log_Ranking'[Date])
			VAR _MaxDate = ('FACT_Log_Ranking'[Date])
			
			VAR target =
			    CALCULATE (
			        SUM ( 'FACT_GSheet_Target_Shop_Daily'[Target] ),
			        FILTER(
			            FACT_GSheet_Target_Shop_Daily,
			            'FACT_GSheet_Target_Shop_Daily'[Type] = "DSO TARGET"
			            && 'FACT_GSheet_Target_Shop_Daily'[Object] = _Shop
			            && 'FACT_GSheet_Target_Shop_Daily'[Date] >= _StartDate
			            && 'FACT_GSheet_Target_Shop_Daily'[Date] <= _MaxDate
			    )
			    )
			VAR dso_iP17 =
			    CALCULATE (
			        [Dso],
			        FILTER (
			            'FACT_Sale_Doanh số bán',
			            CONTAINSSTRING ( 'FACT_Sale_Doanh số bán'[ProductCode], "APP-IP17" )
			            || CONTAINSSTRING ( 'FACT_Sale_Doanh số bán'[ProductCode], "APP-IP-AIR" )
			        ),
			        'FACT_Sale_Doanh số bán'[Date] >= DATE (2025, 9, 19),
			        'FACT_Sale_Doanh số bán'[Date] <= DATE (2025, 9, 24),
			        'FACT_Sale_Doanh số bán'[Shop] = _Shop,
			        'FACT_Sale_Doanh số bán'[Date] >= _StartDate,
			        'FACT_Sale_Doanh số bán'[Date] <= _MaxDate
			    )
			
			RETURN
			    target + dso_iP17
			
			```
		lineageTag: bc3d9925-ccfa-4a5a-ab93-5d29475f93e0
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column 'Target tư vấn smember' =
			
			CALCULATE(
			    AVERAGE(FACT_GSheet_Target_App[Target]),
			    FILTER(
			        FACT_GSheet_Target_App,
			        FACT_GSheet_Target_App[Miền]
			            = EARLIER( 'FACT_Log_Ranking'[MIỀN] )
			            && FACT_GSheet_Target_App[Date] = 'FACT_Log_Ranking'[Date]
			    )
			)
		lineageTag: 2dc4abe4-3ee1-4a47-b85c-4405b4ef2916
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column Tỉnh = RELATED('DIM_Danh mục_Phòng ban'[Province.Shortform])
		lineageTag: 73c7c577-9ead-4775-a09b-f28728a9af9f
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Tổng chỉ tiêu đạt' = ```
			
			VAR esl = IF('FACT_Log_Ranking'[% Target sử dụng ESL] >= 1,1,0)
			VAR app = IF('FACT_Log_Ranking'[% Target lượt tải app] >= 1,1,0)
			VAR nang_suat = IF('FACT_Log_Ranking'[% Target năng suất định biên] >= 1,1,0)
			VAR dao_tao = IF('FACT_Log_Ranking'[% Target tham gia đào tạo] >= 1,1,0)
			VAR khtn = IF('FACT_Log_Ranking'[% Target thu thập KHTN] >= 1,1,0)
			VAR onl = IF('FACT_Log_Ranking'[% Target thành công đơn Online] >= 1,1,0)
			VAR that_thoat = IF('FACT_Log_Ranking'[% Target thất thoát hàng hóa] >= 1,1,0)
			VAR tre_don = IF('FACT_Log_Ranking'[% Target trễ đơn giao hàng] >= 1,1,0)
			VAR turnover = IF('FACT_Log_Ranking'[% Target turnover rate] >= 1,1,0)
			VAR smem = IF('FACT_Log_Ranking'[% Target tư vấn smember] >= 1,1,0)
			VAR _result =
			1*(esl + turnover + nang_suat) + 1*(app + tre_don + onl + that_thoat) + 1*(dao_tao + smem + khtn)
			RETURN _result
			
			```
		formatString: 0
		lineageTag: 49851ab3-a2e0-4c02-b16b-9b2ae816b609
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column 'Xếp hạng cửa hàng' =
			
			RANKX(
			    FILTER(
			        'FACT_Log_Ranking',
			        'FACT_Log_Ranking'[Date]
			            = EARLIER( 'FACT_Log_Ranking'[Date] )
			            && 'FACT_Log_Ranking'[MIỀN]
			            = EARLIER( 'FACT_Log_Ranking'[MIỀN] )
			            && 'FACT_Log_Ranking'[Đánh giá cuối cùng]
			            = EARLIER( 'FACT_Log_Ranking'[Đánh giá cuối cùng] )
			    ),
			    'FACT_Log_Ranking'[Score],
			    [Score],
			    DESC,
			    DENSE
			)
		formatString: 0
		lineageTag: 8ce2e5aa-0b9d-4fba-8cf2-c4056a7e71f7
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column 'Xếp hạng cuối cùng' =
			
			VAR max_xuatsac =
			CALCULATE(
			    DISTINCTCOUNT( 'FACT_Log_Ranking'[SHOP] ),
			    FILTER(
			        'FACT_Log_Ranking',
			            'FACT_Log_Ranking'[MIỀN] = EARLIER( 'FACT_Log_Ranking'[MIỀN] )
			            && 'FACT_Log_Ranking'[Date] = EARLIER( 'FACT_Log_Ranking'[Date] )
			            && 'FACT_Log_Ranking'[Đánh giá cuối cùng] = "Xuất sắc tuyệt đối"
			    )
			)
			VAR max_tot =
			CALCULATE(
			    DISTINCTCOUNT( 'FACT_Log_Ranking'[SHOP] ),
			    FILTER(
			        'FACT_Log_Ranking',
			            'FACT_Log_Ranking'[MIỀN] = EARLIER( 'FACT_Log_Ranking'[MIỀN] )
			            && 'FACT_Log_Ranking'[Date] = EARLIER( 'FACT_Log_Ranking'[Date] )
			            && 'FACT_Log_Ranking'[Đánh giá cuối cùng] = "Tốt"
			    )
			)
			VAR max_kha =
			CALCULATE(
			    DISTINCTCOUNT( 'FACT_Log_Ranking'[SHOP] ),
			    FILTER(
			        'FACT_Log_Ranking',
			            'FACT_Log_Ranking'[MIỀN] = EARLIER( 'FACT_Log_Ranking'[MIỀN] )
			            && 'FACT_Log_Ranking'[Date] = EARLIER( 'FACT_Log_Ranking'[Date] )
			            && 'FACT_Log_Ranking'[Đánh giá cuối cùng] = "Khá"
			    )
			)
			VAR max_kem =
			CALCULATE(
			    DISTINCTCOUNT( 'FACT_Log_Ranking'[SHOP] ),
			    FILTER(
			        'FACT_Log_Ranking',
			            'FACT_Log_Ranking'[MIỀN] = EARLIER( 'FACT_Log_Ranking'[MIỀN] )
			            && 'FACT_Log_Ranking'[Date] = EARLIER( 'FACT_Log_Ranking'[Date] )
			            && 'FACT_Log_Ranking'[Đánh giá cuối cùng] = "Kém"
			    )
			)
			
			RETURN SWITCH(TRUE(),
			'FACT_Log_Ranking'[Đánh giá cuối cùng] = "Tốt",'FACT_Log_Ranking'[Xếp hạng cửa hàng]+max_xuatsac,
			'FACT_Log_Ranking'[Đánh giá cuối cùng] = "Khá",'FACT_Log_Ranking'[Xếp hạng cửa hàng]+max_tot+max_xuatsac,
			'FACT_Log_Ranking'[Đánh giá cuối cùng] = "Kém",'FACT_Log_Ranking'[Xếp hạng cửa hàng]+max_tot+max_xuatsac+max_kha,
			'FACT_Log_Ranking'[Đánh giá cuối cùng] = "Cảnh cáo",'FACT_Log_Ranking'[Xếp hạng cửa hàng]+max_tot+max_xuatsac+max_kha+max_kem,'FACT_Log_Ranking'[Xếp hạng cửa hàng])
		formatString: 0
		lineageTag: 2a72fb60-1f41-45d2-ad5e-7217b9df077a
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column '% Target tham gia đào tạo' = ```
			
			VAR target =
			    0.88
			RETURN 
			    DIVIDE(
			        'FACT_Log_Ranking'[Tỷ lệ tham gia đào tạo],
			        target
			    )
			
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 9c5f8047-abb6-4d51-b250-d19efee1f860
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column '% Target thất thoát hàng hóa' = ```
			
			VAR target =
			    0.05*'FACT_Log_Ranking'[Dso]
			RETURN 
			    COALESCE(
			        DIVIDE(
			        'FACT_Log_Ranking'[Tỷ lệ thất thoát hàng hóa],
			        target,
			        1
			    ),1)
			
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: d53e10b1-3836-4fe7-8369-92b0b68a50c7
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column 'Tỷ lệ lượt tải app' = ```
			
			VAR luot_tai_app =
			    CALCULATE(
			        SUM( F_Combined_Metric_CS[luot_tai_app] ),
			        FILTER(
			            F_Combined_Metric_CS,
			            F_Combined_Metric_CS[bo_phan]
			                = EARLIER( 'FACT_Log_Ranking'[SHOP] )
			                && F_Combined_Metric_CS[date] = ( 'FACT_Log_Ranking'[MaxDate] )
			                && NOT (
			                F_Combined_Metric_CS[date] >= DATE(2025,10,09)
			                && F_Combined_Metric_CS[date] <= DATE(2025,10,15))  
			        )
			    )
			VAR chua_co_app =
			    CALCULATE(
			        SUM( F_Combined_Metric_CS[chua_co_app] ),
			        FILTER(
			            F_Combined_Metric_CS,
			            F_Combined_Metric_CS[bo_phan]
			                = EARLIER( 'FACT_Log_Ranking'[SHOP] )
			                && F_Combined_Metric_CS[date] = ( 'FACT_Log_Ranking'[MaxDate] )
			                && NOT (
			                F_Combined_Metric_CS[date] >= DATE(2025,10,09)
			                && F_Combined_Metric_CS[date] <= DATE(2025,10,15))  
			        )
			    )
			RETURN
			MIN(DIVIDE(luot_tai_app,chua_co_app), 1)
			```
