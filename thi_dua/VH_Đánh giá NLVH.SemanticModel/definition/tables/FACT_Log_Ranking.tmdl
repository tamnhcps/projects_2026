	partition FACT_Log_Ranking = calculated
		mode: import
		source = ```
				
				var _start = CALCULATE (
				    MAX ( 'DIM_Danh mục_Ngày'[Đầu tháng] ),
				    FILTER (
				        'DIM_Danh mục_Ngày',
				        'DIM_Danh mục_Ngày'[Ngày_IsActive] = 1
				    )
				)
				RETURN
				SUMMARIZE(FILTER('FACT_Sale_Doanh số bán', 'FACT_Sale_Doanh số bán'[StartDate] = _start && 'FACT_Sale_Doanh số bán'[StartDate] <= [Maxdate_D] && not 'FACT_Sale_Doanh số bán'[StoreCode] in {"HN.HL","HCM.ONL","HN.B2B","HCM.B2B"}), 'FACT_Sale_Doanh số bán'[Shop],'FACT_Sale_Doanh số bán'[Date])
				
				```

	annotation PBI_Id = aeaab12caafe4b33ae58d1a1b6508853

