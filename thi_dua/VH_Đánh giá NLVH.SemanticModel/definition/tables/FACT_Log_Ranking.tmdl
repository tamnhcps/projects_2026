			CALCULATE(
			    [TurnoverRate],
			    FILTER(
			        'DIM_Danh mục_Phòng ban',
			        'DIM_Danh mục_Phòng ban'[Cửa hàng] = _shop),
			    FILTER(
			        'DIM_Danh mục_Ngày',
			        'DIM_Danh mục_Ngày'[Date] = _maxdate
			    )
			)
