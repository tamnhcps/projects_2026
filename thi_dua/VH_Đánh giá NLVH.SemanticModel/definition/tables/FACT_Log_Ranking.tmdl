	column 'Tỷ lệ trễ đơn giao hàng' = ```
			
			VAR _shop = 'FACT_Log_Ranking'[SHOP]
			VAR _maxdate = 'FACT_Log_Ranking'[MaxDate]
			VAR tre_han_DH = 
			CALCULATE (
			    COUNT('F_Logistics'[Trễ hạn_DH] ),
			    FILTER (
			        'F_Logistics',
			        'F_Logistics'[Trễ hạn_DH]= "Trễ hạn"
			        && F_Logistics[Cửa hàng] = _shop
			        && F_Logistics[Ngày tạo chuyến đi].[Date] = _maxdate
			    )
			)
			VAR tong_phan_loai = 
			CALCULATE (
			    COUNT('F_Logistics'[Trễ hạn_DH] ),
			    FILTER (
			        'F_Logistics',
			        'F_Logistics'[Trễ hạn_DH] <> BLANK()
			        && F_Logistics[Cửa hàng] = _shop
			        && F_Logistics[Ngày tạo chuyến đi].[Date] = _maxdate
			    )
			)
			RETURN
			DIVIDE(tre_han_DH,tong_phan_loai,BLANK())
			```
