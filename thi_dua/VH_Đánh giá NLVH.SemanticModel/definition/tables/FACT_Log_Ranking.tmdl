	column 'Tỷ lệ turnover rate' =
			
			VAR _shop =
			    ('FACT_Log_Ranking'[SHOP])
			VAR _maxdate =
			    ('FACT_Log_Ranking'[MaxDate])
			
			-- Nhân sự còn lại đầu kỳ
