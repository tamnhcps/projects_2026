	column 'Tỷ lệ năng suất định biên' = ```
			
			VAR _shop = 'FACT_Log_Ranking'[SHOP]
			VAR cong = 
			CALCULATE(
			    SUM( 'F_Công chi tiết'[Tổng giờ] ),
			    FILTER(
			        'F_Công chi tiết',
			        'F_Công chi tiết'[Vị trí mới] <> BLANK()
			            && 'F_Công chi tiết'[Vị trí mới] <> "PG"
			            && 'F_Công chi tiết'[Vị trí mới] <> "Tiếp đón"
			            && 'F_Công chi tiết'[IsHocviec] = "Không"
			            && 'F_Công chi tiết'[Phòng ban] = _shop
			            && 'F_Công chi tiết'[Date]
			                = ( 'FACT_Log_Ranking'[MaxDate] )
			    )
			)
			VAR dso = 
			'FACT_Log_Ranking'[Dso]
			VAR nang_suat = DIVIDE(dso,cong)
			VAR target = 
			CALCULATE(
			    AVERAGE('FACT_Công định biên'[Định biên_Năng suất]),
			    FILTER(
			        'FACT_Công định biên',
			        'FACT_Công định biên'[Shop]
			            = EARLIER( 'FACT_Log_Ranking'[SHOP] )
			            && 'FACT_Công định biên'[StartDate] = STARTOFMONTH('FACT_Log_Ranking'[Date])
			    )
			)
			RETURN
			DIVIDE(nang_suat,target)
			```
		lineageTag: 65db89ac-e89b-4720-9ccf-95f46f3d7017
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column 'Tỷ lệ sử dụng ESL' =
			
			VAR _shop = 'FACT_Log_Ranking'[SHOP]   -- measure trả về tên cửa hàng
			VAR _bgdt =
			CALCULATE(
			    SUM(F_PriceTag[Count_MaChaWeb]),
			    FILTER(
			        F_PriceTag,
			        F_PriceTag[branchname] = _shop
			        && F_PriceTag[date] = 'FACT_Log_Ranking'[MaxDate]
			    ))
			VAR _dinhbien =
			CALCULATE(
			    SUM('F_Định biên trưng bày'[ĐỊNH BIÊN TRƯNG BÀY]),
			    FILTER(
			        'F_Định biên trưng bày',
			        'F_Định biên trưng bày'[MÃ SHOP] = _shop
			    )
			)
			RETURN
			MIN(DIVIDE(_bgdt,_dinhbien), 1)
		lineageTag: 9d8face9-6510-44a2-8713-0b93015fc61d
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

