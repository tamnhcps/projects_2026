	column 'Đánh giá cuối cùng' = ```
			
			SWITCH(
			    TRUE(),
			    'FACT_Log_Ranking'[Score] >= 1 && 'FACT_Log_Ranking'[Tổng chỉ tiêu đạt] >= 9, "Xuất sắc tuyệt đối",
			    'FACT_Log_Ranking'[Score] >= 0.8 && 'FACT_Log_Ranking'[Tổng chỉ tiêu đạt] >= 7, "Tốt",
			    'FACT_Log_Ranking'[Score] >= 0.7 && 'FACT_Log_Ranking'[Tổng chỉ tiêu đạt] >= 5, "Khá",
			    'FACT_Log_Ranking'[Score] >= 0.5 && 'FACT_Log_Ranking'[Tổng chỉ tiêu đạt] >= 3, "Kém",
			    'FACT_Log_Ranking'[Score] < 0.5 && 'FACT_Log_Ranking'[Tổng chỉ tiêu đạt] < 3, "Cảnh cáo",
			    "Cảnh cáo"
			)
			
			```
		lineageTag: 7c49c392-4c7f-4692-a4ba-cb66eae329b2
		summarizeBy: none

