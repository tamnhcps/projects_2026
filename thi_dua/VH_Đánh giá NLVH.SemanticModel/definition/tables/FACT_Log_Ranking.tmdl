	column 'Quản lý' = ```
			
			    CALCULATE(CONCATENATEX( VALUES( 'FACT_Đánh giá SM'[SM/SUP] ), 'FACT_Đánh giá SM'[SM/SUP], ", " ),
			    FILTER('FACT_Đánh giá SM',
			        'FACT_Đánh giá SM'[SHOP] = 'FACT_Log_Ranking'[SHOP]
			        && YEAR('FACT_Đánh giá SM'[StartDate]) = YEAR('FACT_Log_Ranking'[Date])
			        && MONTH('FACT_Đánh giá SM'[StartDate]) = MONTH('FACT_Log_Ranking'[Date])))
