	column 'Tỷ lệ thu thập KHTN' =
			
			VAR khtn_customer =
			    CALCULATE(
			        SUM( F_Combined_Metric_CS[khtn_customer] ),
			        FILTER(
			            F_Combined_Metric_CS,
			            F_Combined_Metric_CS[bo_phan]
			                = EARLIER( 'FACT_Log_Ranking'[SHOP] )
			                && F_Combined_Metric_CS[date] = ( 'FACT_Log_Ranking'[MaxDate] )
			        )
			    )
			VAR Target_daily =
			    CALCULATE(
			        SUM( F_Combined_Metric_CS[target_daily_khtn] ),
			        FILTER(
			            F_Combined_Metric_CS,
			            F_Combined_Metric_CS[bo_phan]
			                = EARLIER( 'FACT_Log_Ranking'[SHOP] )
			                && F_Combined_Metric_CS[date] = ( 'FACT_Log_Ranking'[MaxDate] )
			        )
			    )
			RETURN
			MIN(DIVIDE(khtn_customer,Target_daily), 1)
