role 'Vận hành_AM'
	modelPermission: read

	tablePermission 'DIM_Danh mục_Ngày' = 'DIM_Danh mục_Ngày'[Date]>=LOOKUPVALUE('DIM_Phân quyền user'[Startdate],'DIM_Phân quyền user'[Mail],USERPRINCIPALNAME())

	tablePermission 'DIM_Danh mục_Phòng ban' = ```
			VAR zName = 
			    LOOKUPVALUE(
			        'DIM_Phân quyền user'[Tên],
			        'DIM_Phân quyền user'[Mail], 
			        USERPRINCIPALNAME()
			    )
			
			VAR zTable_AddColumns = 
			    ADDCOLUMNS(
			        'DIM_Danh mục_Phòng ban',
			        "zPath",
			        LOOKUPVALUE(
			            'DIM_Phân quyền user'[Path],
			            'DIM_Phân quyền user'[Tên], 
			            'DIM_Danh mục_Phòng ban'[Leader]
			        )
			    )
			
			VAR zFilteredTable = 
			    FILTER(
			        zTable_AddColumns,
			        PATHCONTAINS([zPath], zName)
			    )
			
			VAR zDistinctStores = 
			    DISTINCT(
			        SELECTCOLUMNS(
			            zFilteredTable,
			            "Cửa hàng", 'DIM_Danh mục_Phòng ban'[Cửa hàng]
			        )
			    )
			
			RETURN
			IF(
			    LOOKUPVALUE('DIM_Phân quyền user'[Title], 'DIM_Phân quyền user'[Mail], USERPRINCIPALNAME()) = "AM",
			    [Cửa hàng] IN zDistinctStores,
			    TRUE
			)
			```

	annotation PBI_Id = 04e7a0c8e17d4a6f80972dd0c0a5e9f4

